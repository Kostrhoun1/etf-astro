---
import Layout from '../../layouts/Layout.astro';
import InternalLinking from '../../components/InternalLinking.astro';
import { supabase } from '../../lib/supabase';

export async function getStaticPaths() {
  // Paginate to get ALL ETFs (Supabase has 1000 row limit)
  const allIsins: { isin: string }[] = [];
  const pageSize = 1000;
  let page = 0;
  let hasMore = true;

  while (hasMore) {
    const { data: etfs, error } = await supabase
      .from('etf_funds')
      .select('isin')
      .range(page * pageSize, (page + 1) * pageSize - 1);

    if (error || !etfs || etfs.length === 0) {
      hasMore = false;
    } else {
      allIsins.push(...etfs);
      page++;
      hasMore = etfs.length === pageSize;
    }
  }

  console.log(`getStaticPaths: Found ${allIsins.length} ETFs`);

  return allIsins.map(etf => ({
    params: { isin: etf.isin }
  }));
}

const { isin } = Astro.params;

const { data: etf } = await supabase
  .from('etf_funds')
  .select('*')
  .eq('isin', isin)
  .single();

if (!etf) {
  return Astro.redirect('/404');
}

// Get related ETFs
const { data: relatedETFs } = await supabase
  .from('etf_funds')
  .select('isin, name, primary_ticker, ter_numeric, return_1y, rating, fund_size_numeric')
  .neq('isin', isin)
  .eq('category', etf.category)
  .gte('fund_size_numeric', 50)
  .order('fund_size_numeric', { ascending: false })
  .limit(6);

function formatPercent(value: number | null): string {
  if (value === null || value === undefined) return '-';
  // Database values are already in percent format (e.g., 2.57 means 2.57%)
  return value.toFixed(2) + '%';
}

function formatSize(size: number | null): string {
  if (size === null) return '-';
  if (size >= 1000) return (size / 1000).toFixed(1) + ' mld €';
  return Math.round(size) + ' mil €';
}

function getRatingStars(rating: number | null): string {
  if (rating === null) return '-';
  const stars = Math.round(rating);
  return '★'.repeat(stars) + '☆'.repeat(5 - stars);
}

const ticker = etf.primary_ticker || etf.isin.substring(0, 6);
const currentYear = new Date().getFullYear();

const etfSchema = {
  "@context": "https://schema.org",
  "@type": "FinancialProduct",
  "name": etf.name,
  "identifier": etf.isin,
  "provider": { "@type": "Organization", "name": etf.fund_provider },
  "description": etf.strategy || etf.name
};

const relatedLinks = [
  { title: "Nejlepší ETF", href: "/nejlepsi-etf", description: "Všechny kategorie ETF", icon: "📊" },
  { title: "Kde koupit ETF", href: "/kde-koupit-etf", description: "Srovnání brokerů", icon: "🏦" },
  { title: "Srovnání ETF", href: "/srovnani-etf", description: "Porovnejte ETF", icon: "📈" }
];

// Get top holdings
const topHoldings = [];
for (let i = 1; i <= 10; i++) {
  const name = etf[`holding_${i}_name`];
  const weight = etf[`holding_${i}_weight`];
  if (name && weight) {
    topHoldings.push({ name, weight });
  }
}

// Get top countries
const topCountries = [];
for (let i = 1; i <= 5; i++) {
  const name = etf[`country_${i}_name`];
  const weight = etf[`country_${i}_weight`];
  if (name && weight) {
    topCountries.push({ name, weight });
  }
}

// Get top sectors
const topSectors = [];
for (let i = 1; i <= 5; i++) {
  const name = etf[`sector_${i}_name`];
  const weight = etf[`sector_${i}_weight`];
  if (name && weight) {
    topSectors.push({ name, weight });
  }
}

// Get exchanges
const exchanges = [];
for (let i = 1; i <= 10; i++) {
  const name = etf[`exchange_${i}_name`];
  const ticker = etf[`exchange_${i}_ticker`];
  const currency = etf[`exchange_${i}_currency`];
  if (name && name.trim()) {
    exchanges.push({ name, ticker, currency });
  }
}

function getCountryFlag(countryName: string): string {
  const name = countryName.toLowerCase();
  if (name.includes('united states') || name.includes('usa')) return '🇺🇸';
  if (name.includes('germany') || name.includes('německo')) return '🇩🇪';
  if (name.includes('france') || name.includes('francie')) return '🇫🇷';
  if (name.includes('united kingdom') || name.includes('uk')) return '🇬🇧';
  if (name.includes('japan') || name.includes('japonsko')) return '🇯🇵';
  if (name.includes('china') || name.includes('čína')) return '🇨🇳';
  if (name.includes('switzerland') || name.includes('švýcarsko')) return '🇨🇭';
  if (name.includes('netherlands') || name.includes('nizozemsko')) return '🇳🇱';
  if (name.includes('canada') || name.includes('kanada')) return '🇨🇦';
  if (name.includes('australia') || name.includes('austrálie')) return '🇦🇺';
  if (name.includes('ireland') || name.includes('irsko')) return '🇮🇪';
  if (name.includes('taiwan')) return '🇹🇼';
  if (name.includes('korea')) return '🇰🇷';
  return '🏳️';
}
---

<Layout
  title={ticker + ' - ' + etf.name + ' | ETF průvodce'}
  description={'Detailní analýza ETF ' + etf.name + '. TER ' + formatPercent(etf.ter_numeric) + ', výkonnost, složení portfolia.'}
  canonical={'/etf/' + isin}
>
  <script type="application/ld+json" set:html={JSON.stringify(etfSchema)} />

  <section class="py-12 bg-gradient-to-br from-blue-50 to-indigo-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <a href="/" class="text-gray-500 hover:text-gray-700">Domů</a>
        <span class="text-gray-400">/</span>
        <a href="/nejlepsi-etf" class="text-gray-500 hover:text-gray-700">Nejlepší ETF</a>
        <span class="text-gray-400">/</span>
        <span class="text-gray-900">{ticker}</span>
      </div>

      <div class="grid lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2">
          <div class="flex items-center gap-4 mb-4">
            <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm font-medium">
              {etf.category || 'ETF'}
            </span>
            {etf.distribution_policy && (
              <span class="bg-gray-100 text-gray-700 px-3 py-1 rounded-full text-sm">
                {etf.distribution_policy}
              </span>
            )}
          </div>
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">
            {ticker} - {etf.name}
          </h1>
          <p class="text-gray-600 mb-4">{etf.fund_provider} · ISIN: {etf.isin}</p>
          {etf.strategy && (
            <p class="text-gray-600">{etf.strategy}</p>
          )}

          <!-- Author byline + Last Updated - E-E-A-T signal -->
          <div class="flex flex-wrap items-center gap-2 text-sm text-gray-600 mt-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400">
              <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
            <span>Autor: </span>
            <a href="/o-nas" class="text-violet-600 hover:text-violet-700 font-medium hover:underline">
              Tomáš Kostrhoun
            </a>
            {etf.updated_at && (
              <>
                <span class="text-gray-400">•</span>
                <span>
                  Aktualizováno: {new Date(etf.updated_at).toLocaleDateString('cs-CZ', { day: 'numeric', month: 'numeric', year: 'numeric' })}
                </span>
              </>
            )}
          </div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-lg">
          <div class="text-center mb-4">
            <div class="text-3xl text-yellow-500 mb-2">{getRatingStars(etf.rating)}</div>
            <div class="text-sm text-gray-600">Celkové hodnocení</div>
          </div>
          <div class="space-y-4">
            <div class="flex justify-between">
              <span class="text-gray-600">TER</span>
              <span class="font-bold text-gray-900">{formatPercent(etf.ter_numeric)}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">Velikost fondu</span>
              <span class="font-bold text-gray-900">{formatSize(etf.fund_size_numeric)}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">1R výnos</span>
              <span class:list={['font-bold', etf.return_1y && etf.return_1y > 0 ? 'text-emerald-600' : 'text-red-600']}>
                {formatPercent(etf.return_1y)}
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Výkonnost</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
        <div class="bg-gray-50 rounded-xl p-4 text-center">
          <div class="text-sm text-gray-500 mb-1">YTD</div>
          <div class:list={['text-xl font-bold', etf.return_ytd && etf.return_ytd > 0 ? 'text-emerald-600' : 'text-red-600']}>
