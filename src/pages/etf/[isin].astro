                  <th class="text-right py-3 px-2 text-sm font-medium text-gray-500">Výnos/riziko</th>
                </tr>
              </thead>
              <tbody>
                <tr class="border-b border-gray-100">
                  <td class="py-3 px-2 text-gray-700">1 měsíc</td>
                  <td class="py-3 px-2 text-right font-medium performance-value"
                      data-eur={etf.return_1m ?? ''}
                      data-czk={etf.return_1m_czk ?? ''}
                      data-usd={etf.return_1m_usd ?? ''}>
                    <span class:list={[etf.return_1m_czk && etf.return_1m_czk > 0 ? 'text-emerald-600' : 'text-red-600']}>
                      {etf.return_1m_czk ? etf.return_1m_czk.toFixed(2) + '%' : '-'}
                    </span>
                  </td>
                  <td class="py-3 px-2 text-right text-gray-500">-</td>
                </tr>
                <tr class="border-b border-gray-100">
                  <td class="py-3 px-2 text-gray-700">3 měsíce</td>
                  <td class="py-3 px-2 text-right font-medium performance-value"
                      data-eur={etf.return_3m ?? ''}
                      data-czk={etf.return_3m_czk ?? ''}
                      data-usd={etf.return_3m_usd ?? ''}>
                    <span class:list={[etf.return_3m_czk && etf.return_3m_czk > 0 ? 'text-emerald-600' : 'text-red-600']}>
                      {etf.return_3m_czk ? etf.return_3m_czk.toFixed(2) + '%' : '-'}
                    </span>
                  </td>
                  <td class="py-3 px-2 text-right text-gray-500">-</td>
                </tr>
                <tr class="border-b border-gray-100">
                  <td class="py-3 px-2 text-gray-700">6 měsíců</td>
                  <td class="py-3 px-2 text-right font-medium performance-value"
                      data-eur={etf.return_6m ?? ''}
                      data-czk={etf.return_6m_czk ?? ''}
                      data-usd={etf.return_6m_usd ?? ''}>
                    <span class:list={[etf.return_6m_czk && etf.return_6m_czk > 0 ? 'text-emerald-600' : 'text-red-600']}>
                      {etf.return_6m_czk ? etf.return_6m_czk.toFixed(2) + '%' : '-'}
                    </span>
