                  <td class="py-3 px-2 text-right font-medium performance-value"
                      data-eur={etf.return_ytd ?? ''}
                      data-czk={etf.return_ytd_czk ?? ''}
                      data-usd={etf.return_ytd_usd ?? ''}>
