          <button data-currency="USD" class="currency-btn px-4 py-2 rounded-md text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">
            🇺🇸 USD
          </button>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Výkonnost podle období -->
        <div class="bg-white rounded-xl p-6 shadow border border-gray-100">
