            </div>
            <div class="flex justify-between">
              <dt class="text-gray-600">Měna</dt>
              <dd class="font-medium text-gray-900">{etf.fund_currency || 'EUR'}</dd>
            </div>
          </dl>
        </div>

        <div class="bg-white rounded-xl p-6 shadow">
          <h3 class="font-bold text-gray-900 mb-4">Struktura fondu</h3>
          <dl class="space-y-3">
            <div class="flex justify-between">
              <dt class="text-gray-600">TER</dt>
              <dd class="font-medium text-gray-900">{formatPercent(etf.ter_numeric)}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-gray-600">Velikost fondu</dt>
              <dd class="font-medium text-gray-900">{formatSize(etf.fund_size_numeric)}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-gray-600">Replikace</dt>
              <dd class="font-medium text-gray-900">{etf.replication || '-'}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-gray-600">Dividendy</dt>
              <dd class="font-medium text-gray-900">{etf.distribution_policy || '-'}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-gray-600">Rok založení</dt>
              <dd class="font-medium text-gray-900">{etf.inception_date ? new Date(etf.inception_date).getFullYear() : '-'}</dd>
            </div>
            {etf.index_name && (
              <div class="flex justify-between">
                <dt class="text-gray-600">Sledovaný index</dt>
                <dd class="font-medium text-gray-900">{etf.index_name}</dd>
              </div>
            )}
            {etf.legal_structure && (
              <div class="flex justify-between">
                <dt class="text-gray-600">Právní struktura</dt>
                <dd class="font-medium text-gray-900">{etf.legal_structure}</dd>
              </div>
            )}
            {etf.sustainability && (
              <div class="flex justify-between">
