        </div>
        <div class="bg-gray-50 rounded-xl p-4 text-center">
          <div class="text-sm text-gray-500 mb-1">1 rok</div>
          <div class:list={['text-xl font-bold', etf.return_1y && etf.return_1y > 0 ? 'text-emerald-600' : 'text-red-600']}>
            {formatPercent(etf.return_1y)}
          </div>
        </div>
        <div class="bg-gray-50 rounded-xl p-4 text-center">
          <div class="text-sm text-gray-500 mb-1">3 roky</div>
          <div class:list={['text-xl font-bold', etf.return_3y && etf.return_3y > 0 ? 'text-emerald-600' : 'text-red-600']}>
            {formatPercent(etf.return_3y)}
          </div>
        </div>
        <div class="bg-gray-50 rounded-xl p-4 text-center">
          <div class="text-sm text-gray-500 mb-1">5 let</div>
          <div class:list={['text-xl font-bold', etf.return_5y && etf.return_5y > 0 ? 'text-emerald-600' : 'text-red-600']}>
            {formatPercent(etf.return_5y)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Detailní informace -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Detailní informace</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-white rounded-xl p-6 shadow">
          <h3 class="font-bold text-gray-900 mb-4">Základní informace</h3>
          <dl class="space-y-3">
            <div class="flex justify-between">
              <dt class="text-gray-600">ISIN</dt>
              <dd class="font-medium text-gray-900">{etf.isin}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-gray-600">Ticker</dt>
              <dd class="font-medium text-gray-900">{etf.primary_ticker || '-'}</dd>
            </div>
            <div class="flex justify-between">
