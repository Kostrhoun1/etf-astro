                   data-eur={etf.return_2022 ?? ''}
                   data-czk={etf.return_2022_czk ?? ''}
                   data-usd={etf.return_2022_usd ?? ''}>
                <span class:list={[etf.return_2022_czk && etf.return_2022_czk > 0 ? 'text-emerald-600' : 'text-red-600']}>
                  {etf.return_2022_czk !== null && etf.return_2022_czk !== undefined ? etf.return_2022_czk.toFixed(2) + '%' : '-'}
                </span>
              </div>
            </div>
            <div class="text-center p-4 border border-gray-200 rounded-lg">
              <div class="text-sm text-gray-500 mb-1">2023</div>
              <div class="text-xl font-bold performance-value"
                   data-eur={etf.return_2023 ?? ''}
                   data-czk={etf.return_2023_czk ?? ''}
                   data-usd={etf.return_2023_usd ?? ''}>
                <span class:list={[etf.return_2023_czk && etf.return_2023_czk > 0 ? 'text-emerald-600' : 'text-red-600']}>
                  {etf.return_2023_czk !== null && etf.return_2023_czk !== undefined ? etf.return_2023_czk.toFixed(2) + '%' : '-'}
                </span>
              </div>
            </div>
            <div class="text-center p-4 border border-gray-200 rounded-lg">
              <div class="text-sm text-gray-500 mb-1">2024</div>
              <div class="text-xl font-bold performance-value"
                   data-eur={etf.return_2024 ?? ''}
                   data-czk={etf.return_2024_czk ?? ''}
                   data-usd={etf.return_2024_usd ?? ''}>
                <span class:list={[etf.return_2024_czk && etf.return_2024_czk > 0 ? 'text-emerald-600' : 'text-red-600']}>
                  {etf.return_2024_czk !== null && etf.return_2024_czk !== undefined ? etf.return_2024_czk.toFixed(2) + '%' : '-'}
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Script pro přepínání měny - vanilla JS, žádný React -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll('.currency-btn');
      const values = document.querySelectorAll('.performance-value');
      const label1 = document.getElementById('currency-label');
      const label2 = document.getElementById('currency-label-2');

      // Load saved preference
      const saved = localStorage.getItem('etf-currency-preference') || 'CZK';
      switchCurrency(saved);

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const currency = btn.getAttribute('data-currency');
          localStorage.setItem('etf-currency-preference', currency);
          switchCurrency(currency);
        });
      });

      function switchCurrency(currency) {
        // Update buttons
        buttons.forEach(btn => {
          if (btn.getAttribute('data-currency') === currency) {
            btn.classList.add('bg-white', 'text-gray-900', 'shadow-sm');
            btn.classList.remove('text-gray-600');
          } else {
            btn.classList.remove('bg-white', 'text-gray-900', 'shadow-sm');
            btn.classList.add('text-gray-600');
          }
        });

        // Update labels
        if (label1) label1.textContent = currency;
        if (label2) label2.textContent = currency;

        // Update values
        values.forEach(el => {
          const val = el.getAttribute('data-' + currency.toLowerCase());
          const num = parseFloat(val);
          const span = el.querySelector('span') || el;

          if (val && !isNaN(num)) {
            span.textContent = num.toFixed(2) + '%';
            span.className = num > 0 ? 'text-emerald-600' : 'text-red-600';
          } else {
            span.textContent = '-';
            span.className = 'text-gray-500';
          }
        });
      }
    });
  </script>

  <!-- Popis fondu -->
  {(etf.description_cs || etf.description_en) && (
    <section class="py-12 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Popis fondu</h2>
        <div class="bg-gray-50 rounded-xl p-6 shadow border border-gray-100">
          <p class="text-gray-700 leading-relaxed">
            {etf.description_cs || etf.description_en}
          </p>
        </div>
      </div>
    </section>
  )}

  <!-- Největší pozice (Holdings) -->
  {topHoldings.length > 0 && (
    <section class="py-12 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Největší pozice</h2>
        <div class="bg-white rounded-xl p-6 shadow border border-gray-100">
          <div class="space-y-4">
            {topHoldings.map((holding, index) => (
              <div class="flex items-center gap-4">
                <div class="w-8 h-8 bg-blue-100 text-blue-700 rounded-lg flex items-center justify-center font-bold text-sm">
                  {index + 1}
                </div>
                <div class="flex-1">
                  <div class="flex justify-between items-center mb-1">
                    <span class="font-medium text-gray-900">{holding.name}</span>
                    <span class="font-bold text-gray-900">{holding.weight !== null && holding.weight !== undefined ? holding.weight.toFixed(2) + '%' : '-'}</span>
                  </div>
                  <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                    <div
                      class="h-full bg-gradient-to-r from-blue-500 to-blue-600 rounded-full"
                      style={`width: ${holding.weight !== null && holding.weight !== undefined ? Math.min(holding.weight * 2, 100) : 0}%`}
                    ></div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Geografické rozložení -->
  {topCountries.length > 0 && (
    <section class="py-12 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Geografické rozložení</h2>
        <div class="bg-white rounded-xl p-6 shadow border border-gray-100">
          <div class="space-y-4">
            {topCountries.map((country, index) => {
              const colors = [
                'from-blue-500 to-blue-600',
                'from-emerald-500 to-emerald-600',
                'from-violet-500 to-violet-600',
                'from-amber-500 to-amber-600',
                'from-rose-500 to-rose-600'
              ];
              return (
                <div class="flex items-center gap-4">
                  <div class="text-2xl">{getCountryFlag(country.name)}</div>
                  <div class="flex-1">
                    <div class="flex justify-between items-center mb-1">
                      <span class="font-medium text-gray-900">{country.name}</span>
                      <span class="font-bold text-gray-900">{country.weight !== null && country.weight !== undefined ? country.weight.toFixed(2) + '%' : '-'}</span>
                    </div>
                    <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                      <div
                        class={`h-full bg-gradient-to-r ${colors[index % colors.length]} rounded-full`}
                        style={`width: ${country.weight !== null && country.weight !== undefined ? Math.min(country.weight, 100) : 0}%`}
                      ></div>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Sektorové rozložení -->
  {topSectors.length > 0 && (
    <section class="py-12 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Sektorové rozložení</h2>
        <div class="bg-white rounded-xl p-6 shadow border border-gray-100">
          <div class="space-y-4">
            {topSectors.map((sector, index) => {
              const colors = [
                'from-violet-500 to-violet-600',
                'from-rose-500 to-rose-600',
                'from-amber-500 to-amber-600',
                'from-cyan-500 to-cyan-600',
                'from-violet-500 to-violet-600'
              ];
              const icons = ['💼', '🏭', '💡', '🏥', '🏦'];
              return (
                <div class="flex items-center gap-4">
                  <div class="text-2xl">{icons[index % icons.length]}</div>
                  <div class="flex-1">
                    <div class="flex justify-between items-center mb-1">
                      <span class="font-medium text-gray-900">{sector.name}</span>
                      <span class="font-bold text-gray-900">{sector.weight !== null && sector.weight !== undefined ? sector.weight.toFixed(2) + '%' : '-'}</span>
                    </div>
                    <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                      <div
                        class={`h-full bg-gradient-to-r ${colors[index % colors.length]} rounded-full`}
                        style={`width: ${sector.weight !== null && sector.weight !== undefined ? Math.min(sector.weight, 100) : 0}%`}
                      ></div>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Dividendové informace -->
  {(etf.current_dividend_yield_numeric || etf.dividends_12m_numeric) && (
    <section class="py-12 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Dividendové informace</h2>
        <div class="bg-white rounded-xl p-6 shadow border border-gray-100">
          <dl class="grid grid-cols-2 md:grid-cols-4 gap-6">
            <div>
              <dt class="text-sm text-gray-500 mb-1">Dividendový výnos</dt>
              <dd class="text-xl font-bold text-emerald-600">
                {etf.current_dividend_yield_numeric !== null && etf.current_dividend_yield_numeric !== undefined ? etf.current_dividend_yield_numeric.toFixed(2) + '%' : '-'}
              </dd>
            </div>
            <div>
              <dt class="text-sm text-gray-500 mb-1">Dividendy za 12m</dt>
              <dd class="text-xl font-bold text-gray-900">
                {etf.dividends_12m_numeric !== null && etf.dividends_12m_numeric !== undefined ? etf.dividends_12m_numeric.toFixed(2) + ' ' + (etf.dividends_12m_currency || 'EUR') : '-'}
              </dd>
            </div>
            <div>
              <dt class="text-sm text-gray-500 mb-1">Frekvence</dt>
              <dd class="text-xl font-bold text-gray-900">
                {etf.distribution_frequency || '-'}
              </dd>
            </div>
            <div>
              <dt class="text-sm text-gray-500 mb-1">Způsob</dt>
              <dd class="text-xl font-bold text-gray-900">
                {etf.distribution_policy || '-'}
              </dd>
            </div>
          </dl>
        </div>
      </div>
    </section>
  )}

  <!-- Rizikovost -->
  {(etf.beta || etf.volatility_1y || etf.max_drawdown_1y) && (
    <section class="py-12 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Rizikovost</h2>
        <div class="bg-white rounded-xl p-6 shadow border border-gray-100">
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-gray-200">
                  <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">Metrika</th>
                  <th class="text-right py-3 px-4 text-sm font-medium text-gray-500">Hodnota</th>
                </tr>
              </thead>
              <tbody>
                {(etf.beta !== null && etf.beta !== undefined) && (
                  <tr class="border-b border-gray-100">
                    <td class="py-3 px-4 text-gray-700">Beta</td>
                    <td class="py-3 px-4 text-right font-medium text-gray-900">{etf.beta.toFixed(2)}</td>
                  </tr>
                )}
                {(etf.correlation !== null && etf.correlation !== undefined) && (
                  <tr class="border-b border-gray-100">
                    <td class="py-3 px-4 text-gray-700">Korelace</td>
                    <td class="py-3 px-4 text-right font-medium text-gray-900">{etf.correlation.toFixed(2)}</td>
                  </tr>
                )}
                {etf.tracking_error && (
                  <tr class="border-b border-gray-100">
                    <td class="py-3 px-4 text-gray-700">Tracking error</td>
                    <td class="py-3 px-4 text-right font-medium text-gray-900">{formatPercent(etf.tracking_error)}</td>
                  </tr>
                )}
                {etf.volatility_1y && (
                  <tr class="border-b border-gray-100">
                    <td class="py-3 px-4 text-gray-700">Volatilita (1R)</td>
                    <td class="py-3 px-4 text-right font-medium text-gray-900">{formatPercent(etf.volatility_1y)}</td>
                  </tr>
                )}
                {etf.max_drawdown_1y && (
                  <tr class="border-b border-gray-100">
                    <td class="py-3 px-4 text-gray-700">Max. pokles (1R)</td>
                    <td class="py-3 px-4 text-right font-medium text-red-600">{formatPercent(etf.max_drawdown_1y)}</td>
                  </tr>
                )}
                {etf.max_drawdown_inception && (
                  <tr class="border-b border-gray-100">
                    <td class="py-3 px-4 text-gray-700">Max. pokles celkem</td>
                    <td class="py-3 px-4 text-right font-medium text-red-600">{formatPercent(etf.max_drawdown_inception)}</td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- 🇨🇿 DETAILNÍ HODNOCENÍ - Pro zvídavé investory -->
  <section class="py-12 bg-gradient-to-br from-violet-50 to-blue-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-2">Detailní hodnocení ETF</h2>
        <p class="text-gray-600">Naše expertní analýza ve 5 kategoriích</p>
      </div>
      <ETFRatingDetailed
        ter={etf.ter_numeric}
        fundSize={etf.fund_size_numeric}
        return1y={etf.return_1y}
        return3y={etf.return_3y}
        return5y={etf.return_5y}
        trackingError={etf.tracking_error}
        category={etf.category}
        distributionPolicy={etf.distribution_policy}
        replication={etf.replication}
      />
    </div>
  </section>

  <!-- Obchodní informace (Exchanges) -->
  {exchanges.length > 0 && (
    <section class="py-12 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Obchodní informace</h2>
        <div class="bg-white rounded-xl p-6 shadow border border-gray-100">
          <div class="grid md:grid-cols-3 gap-4 mb-6">
            <div>
              <dt class="text-sm text-gray-500 mb-1">Primární burza</dt>
              <dd class="font-bold text-gray-900">{etf.primary_exchange || exchanges[0]?.name || '-'}</dd>
            </div>
            <div>
              <dt class="text-sm text-gray-500 mb-1">Primární ticker</dt>
              <dd class="font-bold text-gray-900">{etf.primary_ticker || '-'}</dd>
            </div>
            <div>
              <dt class="text-sm text-gray-500 mb-1">Počet burz</dt>
              <dd class="font-bold text-gray-900">{etf.total_exchanges || exchanges.length}</dd>
            </div>
          </div>
          <h3 class="font-bold text-gray-900 mb-4">Všechny burzy</h3>
          <div class="space-y-3">
            {exchanges.map((exchange, index) => (
              <div class="flex items-center gap-4 py-2 border-b border-gray-100 last:border-0">
                <div class="w-6 h-6 bg-blue-100 text-blue-700 rounded-full flex items-center justify-center text-xs font-bold">
                  {index + 1}
                </div>
                <div class="flex-1 grid grid-cols-3 gap-4">
                  <span class="text-gray-900">{exchange.name}</span>
                  <span class="font-mono text-sm text-gray-600">{exchange.ticker || '-'}</span>
                  <span class="text-gray-500">{exchange.currency || '-'}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  {relatedETFs && relatedETFs.length > 0 && (
    <section class="py-12 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Podobná ETF</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          {relatedETFs.map((related) => (
            <a href={'/etf/' + related.isin} class="bg-gray-50 rounded-xl p-4 hover:shadow-md transition-shadow block">
              <div class="font-bold text-gray-900 mb-1">{related.primary_ticker || related.isin}</div>
              <div class="text-sm text-gray-600 line-clamp-1 mb-2">{related.name}</div>
              <div class="flex justify-between text-sm">
                <span class="text-gray-500">TER: {formatPercent(related.ter_numeric)}</span>
                <span class:list={[related.return_1y && related.return_1y > 0 ? 'text-emerald-600' : 'text-red-600']}>
                  {formatPercent(related.return_1y)}
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 🇨🇿 KDE KOUPIT V ČR - Praktické info pro české investory -->
  <section class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-2">Kde koupit v České republice</h2>
        <p class="text-gray-600">Porovnání českých brokerů a reálných nákladů</p>
      </div>
      <CzechBrokerAvailability
        etfName={etf.name}
        isin={etf.isin}
        ter={etf.ter_numeric}
        isPopular={etf.fund_size_numeric > 1000}
      />
    </div>
  </section>

  <section class="py-12 bg-gradient-to-r from-blue-600 to-indigo-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-white mb-4">Chcete koupit {ticker}?</h2>
      <p class="text-blue-100 mb-6">Porovnejte nejlepší brokery pro nákup tohoto ETF</p>
      <a href="/kde-koupit-etf" class="inline-block bg-white text-blue-700 px-8 py-3 rounded-lg font-semibold hover:bg-blue-50 transition-colors">
        Kde koupit ETF →
      </a>
    </div>
  </section>

  <!-- ALTERNATIVY - Help users find better options -->
  <section class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <AlternativesComparison
        currentETF={{
          isin: etf.isin,
          name: etf.name,
          ticker: ticker
        }}
        alternatives={alternatives}
        reason="Pokud vás zajímají podobná ETF ve stejné kategorii, porovnali jsme pro vás 3 nejpopulárnější alternativy."
      />
    </div>
  </section>

  <!-- 🇨🇿 DAŇOVÝ KONTEXT PRO ČR - Kritické info pro české investory -->
  <section class="py-12 bg-gradient-to-br from-green-50 to-emerald-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-2">Daňové hledisko pro české investory</h2>
        <p class="text-gray-600">Co potřebujete vědět o zdanění tohoto ETF v ČR</p>
      </div>
      <CzechTaxContext
        isAccumulating={etf.distribution_policy === 'Accumulating'}
        currency={etf.fund_currency}
        fundName={etf.name}
      />
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <InternalLinking links={relatedLinks} title="Související články" />
  </div>
</Layout>
