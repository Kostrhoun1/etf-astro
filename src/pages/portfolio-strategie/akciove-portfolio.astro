---
import Layout from '../../layouts/Layout.astro';
import { Card, CardContent, CardHeader, CardTitle } from '../../components/ui/card';
import InternalLinking from '../../components/InternalLinking.astro';
import AkcioviPortfolioPerformanceWrapper from '../../components/portfolio/AkcioviPortfolioPerformanceWrapper';
import { getETFLink } from '../../data/etf-mappings';

const portfolioSchema = {
  "@context": "https://schema.org",
  "@type": "FinancialProduct",
  "name": "Akciové Portfolio",
  "description": "Akciová strategie pro zkušené investory. 80% akcie diverzifikované globálně + 20% nemovitosti pro stabilitu s očekávaným výnosem 7-8% ročně.",
  "category": "Investment Strategy",
  "provider": {
    "@type": "Organization",
    "name": "ETF průvodce.cz",
    "url": "https://www.etfpruvodce.cz"
  },
  "audience": {
    "@type": "Audience",
    "audienceType": "Aggressive Investors"
  },
  "feesAndCommissionsSpecification": "TER 0.20-0.45% ročně",
  "interestRate": "7-8% očekávaný výnos ročně",
  "riskRating": "Agresivní",
  "minimumInvestmentHorizon": "15 let"
};

const faqItems = [
  {
    question: "Proč je Akciové Portfolio složené z 80% akcií a 20% nemovitostí?",
    answer: "Toto složení maximalizuje růstový potenciál při zachování určité diverzifikace. 80% akcií poskytuje hlavní růstový motor s historicky nejvyššími výnosy. 20% nemovitostí (REITs) přidává diverzifikaci, pravidelné dividendy a ochranu proti inflaci, aniž by významně snížilo celkový růstový potenciál portfolia."
  },
  {
    question: "Je tato strategie opravdu vhodná jen pro zkušené investory?",
    answer: "Ano, vyžaduje vysokou psychickou odolnost. Musíte zvládnout ztráty 30-50% bez paniky a pokračovat v investování. Mnoho začátečníků prodá na dně trhu ze strachu. Potřebujete minimálně 15-20 let investiční horizont a stabilní příjem. Zkušenost pomáhá, ale klíčová je disciplína a dlouhodobé myšlení."
  },
  {
    question: "Proč tak specifické ETF? Nemohu použít jiné?",
    answer: "Doporučené ETF jsou vybrané pro optimální diverzifikaci: IE00BL25JM42 (hodnotové akcie), IE00BF4RFH31 (malé společnosti), IE00BK5BR626 (emerging markets), IE00B1FZS350 (REITs). Můžete použít alternativy, ale držte se principů - kombinace hodnoty/růstu, velikosti firem, geografické diverzifikace a nemovitostí."
  },
  {
    question: "Jak často rebalancovat a kdy nakupovat?",
    answer: "Rebalancování jednou ročně nebo při odchylce >10% od cílové alokace. Používejte Dollar Cost Averaging - investujte stejnou částku každý měsíc bez ohledu na ceny. Nikdy nečekejte na 'správný čas' k nákupu. V krizích investujte víc, ne méně. Time in market beats timing the market."
  },
  {
    question: "Kolik mohu ztratit a jak dlouho to bude trvat?",
    answer: "Historicky největší ztráty byly 50-60% (dot-com 2000, krize 2008). Recovery trvala 5-7 let. Musíte být připraveni na ztrátu poloviny hodnoty portfolia a pokračovat v investování. Bez této mentální připravenosti tato strategie není pro vás. Pamatujte: ztráty jsou jen na papíře, dokud neprodáte."
  },
  {
    question: "Potřebuji velký kapitál na začátek?",
    answer: "Ne, můžete začít s 10 000 Kč měsíčně. Začněte s jedním širokým ETF (VWCE nebo CSPX) a postupně přidávejte další složky. Při pravidelném investování 10 000 Kč měsíčně dosáhnete za 20 let při 8% výnosu na 6 milionů Kč. Klíčová je pravidelnost, ne velikost počáteční investice."
  },
  {
    question: "Jak se liší od jiných akciových strategií?",
    answer: "Naše strategie kombinuje různé faktory (value/growth, size, geography) místo pouhého sledování jednoho indexu. To poskytuje lepší diverzifikaci než jen S&P 500 nebo FTSE All-World. Přidání REITs snižuje korelaci a volatilitu. Výsledek je optimalizované akciové portfolio s lepším rizikovým profilem."
  },
  {
    question: "Co v době krize a jak psychicky zvládnout ztráty?",
    answer: "V krizi NEPRODÁVEJTE a pokračujte v pravidelném investování. Krize jsou příležitosti, ne katastrofy. Mějte 6-12 měsíců výdajů v emergency fondu. Sledujte dlouhodobé cíle, ne denní výkyvy. Vzdělávejte se o historii trhu. Připomínejte si, že všechny krize skončily a trhy dosáhly nových maxim."
  }
];

const relatedLinks = [
  {
    title: "Backtest portfolia",
    href: "/kalkulacky/backtest-portfolia",
    description: "Otestujte historickou výkonnost Akciového Portfolia"
  },
  {
    title: "Monte Carlo simulátor",
    href: "/kalkulacky/monte-carlo-simulator",
    description: "Prognóza budoucnosti s tisíci scénářů"
  },
  {
    title: "Portfolio strategie přehled",
    href: "/portfolio-strategie",
    description: "Porovnejte všech 5 investičních strategií"
  },
  {
    title: "Dividendové Portfolio",
    href: "/portfolio-strategie/dividendove-portfolio",
    description: "Dividendové akcie s 4% výnosem + růst"
  },
  {
    title: "Nejlepší ETF 2026",
    href: "/nejlepsi-etf/nejlepsi-etf-2026",
    description: "Najdete nejlepší akciové ETF pro vaši strategii"
  }
];
---

<Layout
  title="Akciové Portfolio Strategie | 80% akcie + 20% nemovitosti"
  description="Akciová strategie pro zkušené investory. 80% akcie diverzifikované globálně + 20% nemovitosti pro stabilitu. Minimálně 15letý horizont."
  canonical="/portfolio-strategie/akciove-portfolio"
  keywords="akciové portfolio, agresivní investování, růstové akcie, dlouhodobé investice, ETF akcie, světové akcie, vysoké výnosy, mladí investoři"
  ogImage="/og-akciove-portfolio.jpg"
  ogTitle="Akciové Portfolio Strategie 2026 | 7-8% ročně s ETF"
  ogDescription="Akciová strategie pro zkušené investory. 80% akcie diverzifikované globálně + 20% nemovitosti pro stabilitu s očekávaným výnosem 7-8% ročně."
>
  <div class="bg-white">
    <!-- Modern Hero Section -->
    <section class="relative py-16 md:py-24 bg-gradient-to-br from-gray-50 to-white overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-red-50/50 via-pink-50/30 to-red-50/50"></div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center w-full">

          <!-- Left Content -->
          <div class="space-y-8">
            <div class="inline-flex items-center bg-gradient-to-r from-red-100 to-pink-100 text-red-700 px-6 py-3 rounded-full text-sm font-medium backdrop-blur-sm border border-red-200/50">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
              Akciové Portfolio
            </div>

            <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 leading-tight">
              Akciové{' '}
              <span class="bg-gradient-to-r from-red-600 via-pink-600 to-red-600 bg-clip-text text-transparent">
                Portfolio
              </span>
            </h1>

            <p class="text-xl text-gray-600 leading-relaxed max-w-2xl">
              Strategie pro zkušené investory s <strong>80% akciemi + 20% nemovitostmi</strong>. Kombinuje růstový potenciál s diverzifikací do nemovitostí.
            </p>

            <div class="flex flex-col sm:flex-row gap-4">
              <a
                href="#allocation"
                class="bg-gradient-to-r from-red-600 to-pink-600 hover:from-red-700 hover:to-pink-700 text-white px-8 py-3 text-lg font-semibold rounded-lg transition-all transform hover:scale-105 hover:shadow-lg flex items-center justify-center gap-2 h-12"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
                Zobrazit složení
              </a>
              <a
                href="#vykonnost"
                class="bg-white/80 backdrop-blur-sm border-2 border-red-300 text-red-700 hover:bg-red-50 px-8 py-3 text-lg font-semibold rounded-lg transition-all hover:shadow-lg flex items-center justify-center gap-2 h-12"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Aktuální výnos
              </a>
            </div>
          </div>

          <!-- Right Content - Visual Element -->
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-br from-red-400/20 to-pink-400/20 rounded-3xl transform rotate-3"></div>
            <div class="relative bg-white/90 backdrop-blur-sm rounded-2xl p-8 border border-gray-200/50 shadow-xl">
              <h3 class="text-2xl font-bold text-gray-900 mb-6">Klíčové údaje</h3>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-gray-600">Cílový výnos</span>
                  <span class="text-2xl font-bold text-red-600">7-8%</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-gray-600">Minimální horizont</span>
                  <span class="font-semibold text-gray-900">15+ let</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-gray-600">Akcie</span>
                  <span class="text-2xl font-bold text-red-600">80%</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-gray-600">Nemovitosti</span>
                  <span class="font-semibold text-gray-900">20%</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-gray-600">Riziko</span>
                  <span class="font-semibold text-red-600">Vysoké</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-gray-600">Rebalancing</span>
                  <span class="font-semibold text-gray-900">Ročně</span>
                </div>
              </div>
              <div class="mt-6 p-4 bg-gradient-to-r from-red-50 to-pink-50 rounded-lg border border-red-200">
                <p class="text-sm font-semibold text-red-800">
                  📈 Pro zkušené investory (15+ let)
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(portfolioSchema)} />

    <div class="max-w-6xl mx-auto px-4 py-12">

      <!-- Portfolio Slozeni -->
      <div id="allocation">
        <Card className="mb-12">
          <CardHeader>
            <CardTitle className="flex items-center gap-3">
              <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
              Složení Akciového Portfolia
            </CardTitle>
          </CardHeader>
          <CardContent>
            <div class="space-y-6">
              <div>
                <div class="flex justify-between items-center mb-2">
                  <span class="font-semibold">Světové akcie</span>
                  <span class="text-lg font-bold">80%</span>
                </div>
                <div class="w-full bg-gray-200 rounded-full h-3 mb-1">
                  <div class="bg-blue-600 h-3 rounded-full" style="width: 80%"></div>
                </div>
                <p class="text-sm text-gray-600"><a href="/etf/IE00BK5BQT80" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:underline font-medium">IE00BK5BQT80</a> - Vanguard FTSE All-World UCITS ETF</p>
              </div>

              <div>
                <div class="flex justify-between items-center mb-2">
                  <span class="font-semibold">Nemovitostní investice (REITs)</span>
                  <span class="text-lg font-bold">20%</span>
                </div>
                <div class="w-full bg-gray-200 rounded-full h-3 mb-1">
                  <div class="bg-orange-600 h-3 rounded-full" style="width: 20%"></div>
                </div>
                <p class="text-sm text-gray-600"><a href="/etf/IE00B0M63284" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:underline font-medium">IE00B0M63284</a> - iShares European Property Yield UCITS ETF</p>
              </div>
            </div>

            <div class="mt-6 bg-red-50 p-4 rounded-lg">
              <h4 class="font-semibold mb-2">💡 Klíčové principy</h4>
              <div class="text-sm">
                <div>&#8226; <strong>Globální diverzifikace:</strong> Rozložení rizika napříč čtyři hlavní regiony</div>
                <div>&#8226; <strong>Dlouhodobý růst:</strong> 100% akciová expozice pro maximální potenciál</div>
              </div>
              <p class="text-xs text-gray-500 mt-2">Maximální růst s geografickou diverzifikací</p>
            </div>
          </CardContent>
        </Card>
      </div>

      <!-- Filozofie strategie -->
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <Card>
          <CardHeader>
            <CardTitle className="flex items-center gap-3">
              <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
              Filozofie strategie
            </CardTitle>
          </CardHeader>
          <CardContent className="space-y-4">
            <div class="bg-red-50 p-4 rounded-lg">
              <h4 class="font-semibold mb-2">📈 Value + Growth kombinace</h4>
              <p class="text-sm">Kombinuje stabilní value akcie s růstovým potenciálem malých firem</p>
            </div>
            <div class="bg-orange-50 p-4 rounded-lg">
              <h4 class="font-semibold mb-2">🏠 Nemovitostní diverzifikace</h4>
              <p class="text-sm">REITs poskytují další zdroj růstu a ochranu proti inflaci</p>
            </div>
            <div class="bg-yellow-50 p-4 rounded-lg">
              <h4 class="font-semibold mb-2">🌍 Geografická diverzifikace</h4>
              <p class="text-sm">Expozice na vyspělé i rozvíjející se trhy pro optimální růst</p>
            </div>
            <div class="bg-purple-50 p-4 rounded-lg">
              <h4 class="font-semibold mb-2">⏰ Dlouhodobý horizont</h4>
              <p class="text-sm">Minimálně 15letý horizont pro překonání volatility</p>
            </div>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle className="flex items-center gap-3">
              <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Výhody strategie
            </CardTitle>
          </CardHeader>
          <CardContent>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Nejvyšší dlouhodobý růstový potenciál</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Jednoduchost - jen akciové ETF</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Nejnižší náklady na správu</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Ochrana proti inflaci</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Ideální pro mladé</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Transparentnost a likvidita</span>
              </li>
            </ul>
          </CardContent>
        </Card>
      </div>

      <!-- Aktualni vykonnost -->
      <AkcioviPortfolioPerformanceWrapper client:visible />

      <!-- Implementace podle veku -->
      <Card className="mb-12">
        <CardHeader>
          <CardTitle className="flex items-center gap-3">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Implementace podle životní fáze
          </CardTitle>
        </CardHeader>
        <CardContent>
          <div class="grid md:grid-cols-3 gap-6">
            <div class="bg-green-50 p-6 rounded-lg">
              <h4 class="font-semibold mb-4 text-green-700">🚀 Fáze akumulace (20-40 let)</h4>
              <div class="space-y-2 text-sm">
                <div>&#8226; <strong>100%</strong> akcie</div>
                <div>&#8226; Maximální růst</div>
                <div>&#8226; DCA každý měsíc</div>
                <div>&#8226; Ignorace volatility</div>
              </div>
              <p class="text-xs text-green-600 mt-3">Ideální pro mladé investory</p>
            </div>

            <div class="bg-orange-50 p-6 rounded-lg">
              <h4 class="font-semibold mb-4 text-orange-700">⚖️ Fáze přechodu (40-55 let)</h4>
              <div class="space-y-2 text-sm">
                <div>&#8226; <strong>90%</strong> akcie, 10% dluhopisy</div>
                <div>&#8226; Postupné snižování rizika</div>
                <div>&#8226; Pokračování v akumulaci</div>
                <div>&#8226; Kontrola volatility</div>
              </div>
              <p class="text-xs text-orange-600 mt-3">Příprava na důchod</p>
            </div>

            <div class="bg-red-50 p-6 rounded-lg">
              <h4 class="font-semibold mb-4 text-red-700">🛡️ Před důchodem (55+ let)</h4>
              <div class="space-y-2 text-sm">
                <div>&#8226; <strong>70-80%</strong> akcie</div>
                <div>&#8226; Ochrana kapitálu</div>
                <div>&#8226; Snížení volatility</div>
                <div>&#8226; Přechod na konzervativní</div>
              </div>
              <p class="text-xs text-red-600 mt-3">Ochrana před sequence riskem</p>
            </div>
          </div>
        </CardContent>
      </Card>

      <!-- Prakticka implementace -->
      <Card className="mb-12">
        <CardHeader>
          <CardTitle className="flex items-center gap-3">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Praktická implementace
          </CardTitle>
        </CardHeader>
        <CardContent>
          <div class="grid md:grid-cols-2 gap-8">
            <div>
              <h4 class="font-semibold mb-4">🔥 Pro začátečníky (1 ETF)</h4>
              <div class="space-y-2 text-sm bg-blue-50 p-4 rounded-lg">
                <div class="font-semibold"><a href="/etf/IE00BK5BQT80" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:underline">IE00BK5BQT80</a> - Vanguard FTSE All-World</div>
                <div>&#8226; <strong>100%</strong> alokace</div>
                <div>&#8226; TER: 0,22%</div>
                <div>&#8226; 4000+ společností</div>
                <div>&#8226; Automatická diverzifikace</div>
              </div>
            </div>

            <div>
              <h4 class="font-semibold mb-4">⚡ Pro pokročilé (3 ETF)</h4>
              <div class="space-y-2 text-sm bg-red-50 p-4 rounded-lg">
