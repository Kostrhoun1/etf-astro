---
import Layout from '../../layouts/Layout.astro';
import ETFTable from '../../components/ETFTable.astro';
import InternalLinking from '../../components/InternalLinking.astro';
import Top3ETF from '../../components/etf/Top3ETF.astro';
import Top10Sections from '../../components/etf/Top10Sections.astro';
import { getTopETFsForCategory, categoryConfigs } from '../../lib/etf-data';

const config = categoryConfigs['nejlepsi-dax-etf'];
const etfs = await getTopETFsForCategory(config);
const currentYear = new Date().getFullYear();
const currentDate = new Date().toLocaleDateString('cs-CZ', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
const lastModified = new Date().toISOString();

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": `Nejlepší DAX ETF 2026 - XDAX vs EXS1 vs DAX`,
  "description": `Srovnání nejlepších DAX ETF 2026. XDAX, EXS1, DAX - německé akcie, poplatky TER, výnosy.`,
  "image": "https://etfpruvodce.cz/og-dax-etf.jpg",
  "author": {
    "@type": "Person",
    "name": "Tomáš Kostrhoun",
    "url": "https://etfpruvodce.cz/o-nas#tomas-kostrhoun"
  },
  "publisher": {
    "@type": "Organization",
    "name": "ETF průvodce.cz",
    "logo": {
      "@type": "ImageObject",
      "url": "https://etfpruvodce.cz/logo.png"
    }
  },
  "datePublished": `2025-12-25`,
  "dateModified": lastModified,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://etfpruvodce.cz/nejlepsi-etf/nejlepsi-dax-etf"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Jak jste vybrali TOP 3 nejlepší DAX ETF?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Náš výběr je založen na kombinaci faktorů: nejnižší poplatky TER, velikost fondu, likvidita, tracking error a celková kvalita providera. Data čerpáme z naší databáze a aktualizujeme měsíčně."
      }
    },
    {
      "@type": "Question",
      "name": "Jaký je rozdíl mezi DAX 30 a DAX 40?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Od září 2021 byl DAX rozšířen z 30 na 40 společností pro lepší reprezentaci německé ekonomiky. Nový DAX 40 zahrnuje více technologických a mid-cap firem, ale stále dominují tradiční německé giganty."
      }
    },
    {
      "@type": "Question",
      "name": "Proč investovat do DAX ETF místo evropských?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "DAX ETF nabízí čistou expozici k německé ekonomice, která je motorem Evropy. Německo má unikátní průmyslovou základnu a exportně orientované společnosti, které mohou doplnit širší evropské portfolio."
      }
    },
    {
      "@type": "Question",
      "name": "Jaké jsou náklady na DAX ETF?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "TER (celkové náklady) DAX ETF se pohybují mezi 0,08% až 0,20% ročně. Nejlevnější je Amundi Core DAX ETF s TER 0,08%, následuje Xtrackers DAX UCITS ETF s TER 0,09% a iShares Core DAX ETF s TER 0,20%. DAX ETF patří mezi nejlevnější regionální ETF díky velké konkurenci."
      }
    },
    {
      "@type": "Question",
      "name": "Jaká jsou rizika investice do DAX ETF?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Hlavní rizika DAX ETF zahrnují: koncentraci do jedné země (Německo), vysokou expozici na automobilový průmysl a průmyslové sektory, závislost na globálním obchodu a exportu, a menší diverzifikaci oproti celoevropským nebo globálním ETF. DAX má pouze 40 společností."
      }
    },
    {
      "@type": "Question",
      "name": "Kde koupit DAX ETF v České republice?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "DAX ETF jako Xtrackers DAX (LU0274211480) nebo iShares Core DAX (DE0005933931) můžete koupit u většiny českých brokerů včetně Degiro, Interactive Brokers, XTB, Trading212, Portu nebo Fio e-Broker. Porovnejte si transakční poplatky jednotlivých brokerů."
      }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "ETF průvodce.cz",
      "item": "https://etfpruvodce.cz"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Nejlepší ETF",
      "item": "https://etfpruvodce.cz/nejlepsi-etf"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Nejlepší DAX ETF",
      "item": "https://etfpruvodce.cz/nejlepsi-etf/nejlepsi-dax-etf"
    }
  ]
};

const relatedLinks = [
  { title: "Nejlepší FTSE ETF", href: "/nejlepsi-etf/nejlepsi-ftse100-etf", description: "Britské blue chip ETF na FTSE indexy", icon: "🇬🇧" },
  { title: "Nejlepší evropské ETF", href: "/nejlepsi-etf/nejlepsi-evropske-etf", description: "Kompletní srovnání evropských ETF fondů", icon: "🇪🇺" },
  { title: "Kde koupit DAX ETF", href: "/kde-koupit-etf", description: "Srovnání brokerů pro investice do německých ETF", icon: "🏦" },
  { title: "Portfolio strategie", href: "/portfolio-strategie", description: "Jak sestavit portfolio s německými ETF", icon: "📊" }
];
---

<Layout
  title={`Nejlepší DAX ETF 2026 - XDAX vs EXS1 vs DAX`}
  description={`✅ Srovnání nejlepších DAX ETF 2026. XDAX, EXS1, DAX - německé akcie, poplatky TER, výnosy. Kompletní analýza DAX 40 indexu k ${currentDate}.`}
  canonical="/nejlepsi-etf/nejlepsi-dax-etf"
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Hero Section -->
  <section class="relative py-16 md:py-24 bg-gradient-to-br from-gray-50 to-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-gray-50/50 via-slate-50/30 to-zinc-50/50"></div>
    <div class="absolute top-20 left-1/4 w-72 h-72 bg-gradient-to-br from-gray-200 to-slate-200 rounded-full mix-blend-multiply filter blur-xl opacity-30"></div>
    <div class="absolute top-40 right-1/4 w-72 h-72 bg-gradient-to-br from-slate-200 to-zinc-200 rounded-full mix-blend-multiply filter blur-xl opacity-30"></div>
    <div class="absolute bottom-20 left-1/3 w-72 h-72 bg-gradient-to-br from-zinc-200 to-neutral-200 rounded-full mix-blend-multiply filter blur-xl opacity-30"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center w-full">
        <!-- Left Column - Content -->
        <div class="space-y-8">
          <div class="inline-flex items-center bg-gradient-to-r from-gray-100 to-slate-100 text-gray-700 px-6 py-3 rounded-full text-sm font-medium backdrop-blur-sm border border-gray-200/50">
            🇩🇪 Aktuální k {currentDate}
          </div>

          <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 leading-tight">
            Nejlepší
            <span class="bg-gradient-to-r from-gray-600 via-slate-600 to-zinc-600 bg-clip-text text-transparent">
              DAX ETF
            </span>
          </h1>

          <!-- Author byline - E-E-A-T signal -->
          <div class="flex flex-wrap items-center gap-2 text-sm text-gray-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400">
              <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
            <span>Autor: </span>
            <a href="/o-nas" class="text-violet-600 hover:text-violet-700 font-medium hover:underline">
              Tomáš Kostrhoun
            </a>
            <span class="text-gray-400">•</span>
            <span>Aktualizováno: {new Date().toLocaleDateString('cs-CZ')}</span>
          </div>

          <p class="text-xl text-gray-600 leading-relaxed max-w-2xl">
            Kompletní srovnání nejlepších ETF fondů na DAX index. Analýza poplatků, výnosů a praktické tipy pro investice do německých blue chip společností.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#top3" class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-gray-600 to-slate-600 hover:from-gray-700 hover:to-slate-700 text-white px-8 py-4 text-lg font-semibold shadow-lg hover:shadow-xl transition-all rounded-lg">
              ⭐ Top 3 doporučení
            </a>
            <a href="#srovnani" class="inline-flex items-center justify-center gap-2 border-2 border-gray-300 text-gray-700 hover:bg-gray-50 px-8 py-4 text-lg font-semibold rounded-lg transition-colors">
              📊 Srovnání všech
            </a>
          </div>
        </div>

        <!-- Right Column - Stats Box -->
        <div class="relative">
          <div class="bg-gradient-to-br from-white/80 to-gray-50/60 backdrop-blur-sm rounded-3xl p-8 shadow-2xl border border-white/20">
            <div class="text-center mb-8">
              <h3 class="text-2xl font-bold text-gray-900 mb-2">🇩🇪 DAX Stats</h3>
              <p class="text-gray-600">Klíčové informace o německém indexu</p>
            </div>

            <div class="grid grid-cols-2 gap-6 mb-6">
              <div class="text-center p-4 bg-gradient-to-r from-gray-50 to-slate-50 rounded-xl border border-gray-200">
                <div class="text-3xl font-bold text-gray-600 mb-1">40</div>
                <div class="text-sm text-gray-600">Německých firem</div>
              </div>
              <div class="text-center p-4 bg-gradient-to-r from-slate-50 to-zinc-50 rounded-xl border border-slate-200">
                <div class="text-3xl font-bold text-slate-600 mb-1">~8%</div>
                <div class="text-sm text-gray-600">Ročně za 20 let</div>
              </div>
              <div class="text-center p-4 bg-gradient-to-r from-zinc-50 to-neutral-50 rounded-xl border border-zinc-200">
                <div class="text-3xl font-bold text-zinc-600 mb-1">75%</div>
                <div class="text-sm text-gray-600">Německý tržní cap</div>
              </div>
              <div class="text-center p-4 bg-gradient-to-r from-neutral-50 to-gray-50 rounded-xl border border-neutral-200">
                <div class="text-3xl font-bold text-neutral-600 mb-1">{etfs.length}</div>
                <div class="text-sm text-gray-600">ETF na výběr</div>
              </div>
            </div>

            <div class="text-center pt-6 border-t border-gray-200/50">
              <p class="text-sm text-gray-600 mb-3">Motor evropské ekonomiky</p>
              <a href="#pruvodce" class="inline-flex items-center justify-center border border-gray-200 text-gray-600 hover:bg-gray-50 px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                Průvodce výběrem
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Introduction Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          Co je DAX index?
        </h2>
        <p class="text-xl md:text-2xl text-gray-600 max-w-4xl mx-auto leading-relaxed">
          DAX sleduje 40 největších německých společností jako SAP, Siemens, BMW, Volkswagen a další.
          Reprezentuje největší evropskou ekonomiku a průmyslovou sílu kontinentu.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
        <div class="bg-white rounded-lg p-6 hover:shadow-md transition-shadow group">
          <div class="flex items-center justify-center rounded-full bg-gradient-to-r from-gray-500 to-slate-600 w-16 h-16 mx-auto mb-6 group-hover:scale-110 transition-transform">
            <span class="text-2xl">👑</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3 text-center group-hover:text-gray-800 transition-colors">
            40 největších firem Německa
          </h3>
          <p class="text-gray-600 leading-relaxed text-center">
            DAX pokrývá německé giganty napříč sektory - od automobilového průmyslu přes technologie až po finance a chemii.
          </p>
        </div>

        <div class="bg-white rounded-lg p-6 hover:shadow-md transition-shadow group">
          <div class="flex items-center justify-center rounded-full bg-gradient-to-r from-slate-500 to-zinc-600 w-16 h-16 mx-auto mb-6 group-hover:scale-110 transition-transform">
            <span class="text-2xl">📍</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3 text-center group-hover:text-gray-800 transition-colors">
            Exportní ekonomika
          </h3>
          <p class="text-gray-600 leading-relaxed text-center">
            Německé společnosti jsou globální lídři v automobilovém průmyslu, strojírenství a high-tech výrobě.
          </p>
        </div>

        <div class="bg-white rounded-lg p-6 hover:shadow-md transition-shadow group">
          <div class="flex items-center justify-center rounded-full bg-gradient-to-r from-zinc-500 to-neutral-600 w-16 h-16 mx-auto mb-6 group-hover:scale-110 transition-transform">
            <span class="text-2xl">🏛️</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3 text-center group-hover:text-gray-800 transition-colors">
            75% německého trhu
          </h3>
          <p class="text-gray-600 leading-relaxed text-center">
            DAX reprezentuje přibližně 75% celkové tržní kapitalizace německých akcií a je motorem evropské ekonomiky.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Top 3 Recommendations -->
  <section id="top3" class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          🏆 Top 3 ETF v této kategorii
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Naše doporučení na základě analýzy {etfs.length} ETF fondů
        </p>
      </div>
      <Top3ETF etfs={etfs} currency="EUR" />
    </div>
  </section>

  <!-- Top 10 Sections -->
  <section id="srovnani" class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Top10Sections etfs={etfs} currency="EUR" categoryName="DAX" />
    </div>
  </section>

  <!-- Selection Guide -->
  <section id="pruvodce" class="py-20 bg-gradient-to-br from-gray-50 to-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <div class="inline-flex items-center justify-center w-20 h-20 bg-gradient-to-r from-gray-600 to-slate-600 rounded-full mb-6">
          <span class="text-3xl">🎯</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          💡 Jak vybrat ten správný DAX ETF?
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="relative p-8 rounded-2xl bg-gradient-to-br from-green-50 to-emerald-50 border border-green-200 hover:shadow-lg transition-all">
          <div class="absolute -top-4 left-8 w-8 h-8 rounded-full bg-gradient-to-r from-green-400 to-emerald-500 flex items-center justify-center text-white font-bold text-sm">1</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4 mt-4">Pro začátečníky</h3>
          <p class="text-gray-700 leading-relaxed">
            Vyberte ETF s nejnižšími poplatky a velkou velikostí fondu. Zaměřte se na standardní DAX tracking bez ESG filtrů pro nejlepší replikaci indexu.
          </p>
        </div>

        <div class="relative p-8 rounded-2xl bg-gradient-to-br from-blue-50 to-blue-50 border border-blue-200 hover:shadow-lg transition-all">
          <div class="absolute -top-4 left-8 w-8 h-8 rounded-full bg-gradient-to-r from-blue-400 to-blue-500 flex items-center justify-center text-white font-bold text-sm">2</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4 mt-4">Pro pokročilé</h3>
          <p class="text-gray-700 leading-relaxed">
            Porovnejte physical vs synthetic replikaci podle vašich preferencí. Sledujte tracking difference a spread podle objemu obchodování.
          </p>
        </div>

        <div class="relative p-8 rounded-2xl bg-gradient-to-br from-purple-50 to-purple-50 border border-purple-200 hover:shadow-lg transition-all">
          <div class="absolute -top-4 left-8 w-8 h-8 rounded-full bg-gradient-to-r from-purple-400 to-purple-500 flex items-center justify-center text-white font-bold text-sm">3</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4 mt-4">Pro ESG investory</h3>
          <p class="text-gray-700 leading-relaxed">
            Zvažte ESG-filtrované verze DAX indexu, které vylučují kontroverzní sektory při zachování expozice na německou ekonomiku.
          </p>
        </div>

        <div class="relative p-8 rounded-2xl bg-gradient-to-br from-orange-50 to-orange-50 border border-orange-200 hover:shadow-lg transition-all">
          <div class="absolute -top-4 left-8 w-8 h-8 rounded-full bg-gradient-to-r from-orange-400 to-orange-500 flex items-center justify-center text-white font-bold text-sm">4</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4 mt-4">Pro diverzifikaci</h3>
          <p class="text-gray-700 leading-relaxed">
            DAX ETF jsou ideální doplněk k širším evropským nebo globálním ETF. Přidávají specifickou expozici k německému průmyslu.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          ❓ Často kladené otázky
        </h2>
      </div>

      <div class="space-y-8">
        <details class="group border border-gray-200 rounded-lg hover:border-gray-300 transition-colors">
          <summary class="flex justify-between items-center w-full px-6 py-4 text-left bg-gray-50 cursor-pointer hover:bg-gray-100 rounded-lg group-open:rounded-b-none transition-colors">
            <span class="font-semibold text-lg text-gray-900 group-hover:text-gray-800">Jak jste vybrali TOP 3 DAX ETF?</span>
            <svg class="w-5 h-5 text-gray-500 group-hover:text-gray-600 transition-all group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 py-4 text-gray-700 leading-relaxed bg-white rounded-b-lg">
            Výběr je založen na kombinaci faktorů: nejnižší poplatky TER, velikost fondu, likvidita, tracking error a celková kvalita providera. Data čerpáme z naší databáze a aktualizujeme měsíčně.
          </div>
        </details>

        <details class="group border border-gray-200 rounded-lg hover:border-gray-300 transition-colors">
          <summary class="flex justify-between items-center w-full px-6 py-4 text-left bg-gray-50 cursor-pointer hover:bg-gray-100 rounded-lg group-open:rounded-b-none transition-colors">
            <span class="font-semibold text-lg text-gray-900 group-hover:text-gray-800">Co znamenají TOP 10 žebříčky na této stránce?</span>
            <svg class="w-5 h-5 text-gray-500 group-hover:text-gray-600 transition-all group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 py-4 text-gray-700 leading-relaxed bg-white rounded-b-lg">
            Žebříčky ukazují nejlepší DAX ETF podle různých kritérií - nejnižší poplatky, největší velikost fondu a nejvyšší výnosy za poslední rok. Data jsou živá z naší databáze.
          </div>
        </details>

        <details class="group border border-gray-200 rounded-lg hover:border-gray-300 transition-colors">
          <summary class="flex justify-between items-center w-full px-6 py-4 text-left bg-gray-50 cursor-pointer hover:bg-gray-100 rounded-lg group-open:rounded-b-none transition-colors">
            <span class="font-semibold text-lg text-gray-900 group-hover:text-gray-800">Proč se některé DAX ETF neobjevují v seznamech?</span>
            <svg class="w-5 h-5 text-gray-500 group-hover:text-gray-600 transition-all group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 py-4 text-gray-700 leading-relaxed bg-white rounded-b-lg">
            Odfiltrováváme malé fondy (pod 100 mil EUR), pákové produkty, tematické a sektorové ETF. Zaměřujeme se pouze na kvalitní ETF sledující široký DAX index.
          </div>
        </details>

        <details class="group border border-gray-200 rounded-lg hover:border-gray-300 transition-colors">
