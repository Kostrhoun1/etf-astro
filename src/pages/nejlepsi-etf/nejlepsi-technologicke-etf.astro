---
import Layout from '../../layouts/Layout.astro';
import InternalLinking from '../../components/InternalLinking.astro';
import Top3ETFServer from '../../components/etf/Top3ETFServer';
import Top10SectionsServer from '../../components/etf/Top10SectionsServer';
import { getTopETFsForCategory, categoryConfigs } from '../../lib/etf-data';

const config = categoryConfigs['nejlepsi-technologicke-etf'];
const etfs = await getTopETFsForCategory(config);
const currentYear = new Date().getFullYear();
const currentDate = new Date().toLocaleDateString('cs-CZ', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
const lastModified = new Date().toISOString().split('T')[0];

// JSON-LD strukturovaná data pro SEO
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
