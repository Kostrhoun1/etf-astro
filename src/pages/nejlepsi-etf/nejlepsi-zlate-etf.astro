---
import Layout from '../../layouts/Layout.astro';
import InternalLinking from '../../components/InternalLinking.astro';
import Top3ETF from '../../components/etf/Top3ETF.astro';
import Top10Sections from '../../components/etf/Top10Sections.astro';
import { getTopETFsForCategory, categoryConfigs } from '../../lib/etf-data';

const config = categoryConfigs['nejlepsi-zlate-etf'];
const etfs = await getTopETFsForCategory(config);
const currentYear = new Date().getFullYear();
const currentDate = new Date().toLocaleDateString('cs-CZ', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
const lastModified = new Date().toISOString();

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": `Nejlepší zlaté ETF 2026 - ZGLD vs PHAU vs SGLD`,
  "description": `Kompletní srovnání nejlepších zlatých ETF 2026. Fyzické zlato vs papírové zlato - poplatky TER, způsob držení, výnosy.`,
  "image": "https://etfpruvodce.cz/og-gold-etf.jpg",
  "author": {
    "@type": "Person",
    "name": "Tomáš Kostrhoun",
    "url": "https://etfpruvodce.cz/o-nas#tomas-kostrhoun"
  },
  "publisher": {
    "@type": "Organization",
    "name": "ETF průvodce.cz",
    "logo": {
      "@type": "ImageObject",
      "url": "https://etfpruvodce.cz/logo.png"
    }
  },
  "datePublished": `2025-12-15`,
  "dateModified": lastModified,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://etfpruvodce.cz/nejlepsi-etf/nejlepsi-zlate-etf"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `Jaké jsou nejlepší zlaté ETF v roce 2026?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Nejlepší zlaté ETF jsou: ${etfs[0]?.name || 'iShares Physical Gold ETC'} (SGLD), ${etfs[1]?.name || 'WisdomTree Physical Gold'} (PHAU), a ${etfs[2]?.name || 'Xetra-Gold'} (XGLD). Tyto ETF jsou kryty fyzickým zlatem a nabízí nejnižší náklady.`
      }
    },
    {
      "@type": "Question",
      "name": "Jaký je rozdíl mezi zlatým ETF a ETC?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "ETF (Exchange-Traded Fund) je fond, zatímco ETC (Exchange-Traded Commodity) je dluhový cenný papír krytý komoditou. Většina 'zlatých ETF' jsou technicky ETC kryté fyzickým zlatem. Pro investory je rozdíl minimální."
      }
    },
    {
      "@type": "Question",
      "name": "Proč investovat do zlata přes ETF místo fyzického zlata?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Zlaté ETF nabízejí nižší náklady na skladování a pojištění, jednoduchý nákup a prodej na burze, žádné starosti s úschovou a možnost investovat malé částky."
      }
    },
    {
      "@type": "Question",
      "name": "Jaké jsou náklady na zlaté ETF?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "TER (celkové náklady) zlatých ETF se obvykle pohybují mezi 0,10% až 0,50% ročně. Fyzicky zajištěné ETF zahrnují náklady na skladování a pojištění zlata. Aktuální TER jednotlivých ETF najdete v našem srovnání nahoře."
      }
    },
    {
      "@type": "Question",
      "name": "Kde je uloženo zlato v zlatých ETF?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Zlato ve fyzicky zajištěných ETF je uloženo v certifikovaných LBMA trezorech, nejčastěji v Londýně, Curychu nebo New Yorku. Každý zlatý slitek je evidován a pravidelně auditován nezávislými auditory. Investoři mohou často nahlédnout do seznamu slitků online."
      }
    },
    {
      "@type": "Question",
      "name": "Jak jsou zlaté ETF zdaněny v České republice?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Zisky ze zlatých ETF/ETC jsou v ČR zdaněny jako kapitálové příjmy sazbou 15%. Po 3 letech držení jsou zisky osvobozeny od daně (časový test). ETC struktura má stejné daňové zacházení jako běžné ETF. Doporučujeme konzultaci s daňovým poradcem."
      }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Domů", "item": "https://etfpruvodce.cz" },
    { "@type": "ListItem", "position": 2, "name": "Nejlepší ETF", "item": "https://etfpruvodce.cz/nejlepsi-etf" },
    { "@type": "ListItem", "position": 3, "name": "Nejlepší zlaté ETF", "item": "https://etfpruvodce.cz/nejlepsi-etf/nejlepsi-zlate-etf" }
  ]
};

const relatedLinks = [
  { title: "Nejlepší komoditní ETF", href: "/nejlepsi-etf/nejlepsi-komoditni-etf", description: "Diverzifikované komodity a suroviny", icon: "🛢️" },
  { title: "Nejlepší dluhopisové ETF", href: "/nejlepsi-etf/nejlepsi-dluhopisove-etf", description: "Státní a korporátní dluhopisy", icon: "💵" },
  { title: "Nejlepší nemovitostní ETF", href: "/nejlepsi-etf/nejlepsi-nemovitostni-etf", description: "REIT fondy a nemovitosti", icon: "🏠" }
];
---

<Layout
  title={`Nejlepší Zlaté ETF 2026 | Fyzické vs Papírové Zlato`}
  description={`✅ Kompletní srovnání nejlepších zlatých ETF 2026. SGLD, PHAU, XGLD - fyzické zlato, poplatky TER, velikost fondů. Aktuální data k ${currentDate}.`}
  canonical="/nejlepsi-etf/nejlepsi-zlate-etf"
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Hero Section -->
  <section class="relative py-16 md:py-24 bg-gradient-to-br from-gray-50 to-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-yellow-50/50 via-amber-50/30 to-orange-50/50"></div>
    <div class="absolute top-20 left-1/4 w-72 h-72 bg-gradient-to-br from-yellow-200 to-amber-200 rounded-full mix-blend-multiply filter blur-xl opacity-30"></div>
    <div class="absolute top-40 right-1/4 w-72 h-72 bg-gradient-to-br from-amber-200 to-orange-200 rounded-full mix-blend-multiply filter blur-xl opacity-30"></div>
    <div class="absolute bottom-20 left-1/3 w-72 h-72 bg-gradient-to-br from-orange-200 to-yellow-200 rounded-full mix-blend-multiply filter blur-xl opacity-30"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center w-full">
        <div class="space-y-8">
          <div class="inline-flex items-center bg-gradient-to-r from-yellow-100 to-amber-100 text-yellow-700 px-6 py-3 rounded-full text-sm font-medium backdrop-blur-sm border border-yellow-200/50">
            🥇 Aktuální k {currentDate}
          </div>

          <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 leading-tight">
            Nejlepší
            <span class="bg-gradient-to-r from-yellow-600 via-amber-600 to-orange-600 bg-clip-text text-transparent">
              zlaté ETF
            </span>
          </h1>

          <!-- Author byline -->
          <div class="flex flex-wrap items-center gap-2 text-sm text-gray-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400">
              <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
            <span>Autor: </span>
            <a href="/o-nas" class="text-violet-600 hover:text-violet-700 font-medium hover:underline">Tomáš Kostrhoun</a>
            <span class="text-gray-400">•</span>
            <span>Aktualizováno: {new Date().toLocaleDateString('cs-CZ')}</span>
          </div>

          <p class="text-xl text-gray-600 leading-relaxed max-w-2xl">
            Kompletní srovnání nejlepších ETF fondů na fyzické zlato.
            SGLD, PHAU, XGLD - poplatky TER, způsob držení, likvidita.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#top3" class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-yellow-600 to-amber-600 hover:from-yellow-700 hover:to-amber-700 text-white px-8 py-3 text-lg font-semibold shadow-lg hover:shadow-xl transition-all rounded-lg">
              ⭐ Top 3 doporučení
            </a>
            <a href="#srovnani" class="inline-flex items-center justify-center gap-2 border-2 border-gray-300 text-gray-700 hover:bg-gray-50 px-8 py-3 text-lg font-semibold rounded-lg transition-colors">
              🥇 Zlaté ETF
            </a>
          </div>
        </div>

        <!-- Stats Box -->
        <div class="relative mt-12">
          <div class="bg-white rounded-2xl p-6 border border-gray-300 shadow-lg">
            <div class="text-center mb-6">
              <div class="inline-flex items-center justify-center w-12 h-12 bg-yellow-100 rounded-xl mb-3">
                <span class="text-2xl">🥇</span>
              </div>
              <h3 class="text-lg font-semibold text-gray-800 mb-1">Zlatý trh v číslech</h3>
              <p class="text-sm text-gray-600">Klíčové metriky pro investice do zlata</p>
            </div>

            <div class="grid grid-cols-2 gap-3 mb-6">
              <div class="bg-white rounded-lg p-4 border border-gray-200 hover:border-yellow-200 transition-colors">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-yellow-600">🌍</span>
                  <span class="text-xs text-gray-500 font-medium">GLOBÁLNÍ TRH</span>
                </div>
                <div class="text-2xl font-bold text-gray-900">$13T+</div>
                <div class="text-xs text-gray-600">celková tržní hodnota</div>
              </div>

              <div class="bg-white rounded-lg p-4 border border-gray-200 hover:border-amber-200 transition-colors">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-amber-600">🏆</span>
                  <span class="text-xs text-gray-500 font-medium">LBMA TREZORY</span>
                </div>
                <div class="text-2xl font-bold text-gray-900">Londýn</div>
                <div class="text-xs text-gray-600">hlavní úložiště</div>
              </div>

              <div class="bg-white rounded-lg p-4 border border-gray-200 hover:border-yellow-200 transition-colors">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-yellow-600">🛡️</span>
                  <span class="text-xs text-gray-500 font-medium">FYZICKÉ KRYTÍ</span>
                </div>
                <div class="text-2xl font-bold text-gray-900">100%</div>
                <div class="text-xs text-gray-600">u doporučených ETF</div>
              </div>

              <div class="bg-white rounded-lg p-4 border border-gray-200 hover:border-amber-200 transition-colors">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-amber-600">📈</span>
                  <span class="text-xs text-gray-500 font-medium">HIST. RŮST</span>
                </div>
                <div class="text-2xl font-bold text-gray-900">~8%</div>
                <div class="text-xs text-gray-600">průměr p.a. (20 let)</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Introduction Section -->
  <section id="uvod" class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <div class="flex items-center justify-center rounded-full bg-yellow-100 w-20 h-20 mx-auto mb-8 hover:bg-yellow-200 transition-colors">
          <span class="text-3xl">🥇</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">Co jsou zlaté ETF?</h2>
        <p class="text-xl md:text-2xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
          Investiční fondy zaměřené na fyzické zlato
          pro ochranu před inflací a krizové situace
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
        <div class="bg-white rounded-lg p-6 hover:shadow-md transition-shadow group">
          <div class="flex items-center justify-center rounded-full bg-gradient-to-r from-yellow-500 to-amber-600 w-16 h-16 mx-auto mb-6 group-hover:scale-110 transition-transform">
            <span class="text-2xl">🛡️</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3 text-center group-hover:text-yellow-800 transition-colors">Bezpečné útočiště</h3>
          <p class="text-gray-600 leading-relaxed text-center">
            Zlato je tisíciletí považováno za bezpečné útočiště během krizí.
            Zachovává hodnotu při ekonomických otřesech a geopolitických napětích.
          </p>
        </div>

        <div class="bg-white rounded-lg p-6 hover:shadow-md transition-shadow group">
          <div class="flex items-center justify-center rounded-full bg-gradient-to-r from-amber-500 to-orange-600 w-16 h-16 mx-auto mb-6 group-hover:scale-110 transition-transform">
            <span class="text-2xl">💰</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3 text-center group-hover:text-amber-800 transition-colors">Fyzické zajištění</h3>
          <p class="text-gray-600 leading-relaxed text-center">
            Nejlepší zlaté ETF jsou 100% zajištěny fyzickým zlatem uloženým
            v auditovaných trezorech s plnou transparentností a pojištěním.
          </p>
        </div>

        <div class="bg-white rounded-lg p-6 hover:shadow-md transition-shadow group">
          <div class="flex items-center justify-center rounded-full bg-gradient-to-r from-orange-500 to-yellow-600 w-16 h-16 mx-auto mb-6 group-hover:scale-110 transition-transform">
            <span class="text-2xl">📈</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3 text-center group-hover:text-orange-800 transition-colors">Ochrana před inflací</h3>
          <p class="text-gray-600 leading-relaxed text-center">
            Zlato historicky roste s inflací a chrání kupní sílu.
            Poskytuje reálné výnosy při znehodnocování měny.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Top 3 ETF Section -->
  <section id="top3" class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          🏆 Top 3 nejlepší zlaté ETF
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Naše doporučení na základě analýzy {etfs.length} zlatých ETF fondů
        </p>
      </div>
      <Top3ETF etfs={etfs} currency="EUR" />
    </div>
  </section>

  <section id="srovnani" class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Top10Sections etfs={etfs} currency="EUR" categoryName="zlaté" />
    </div>
  </section>

  <!-- Selection Guide Section -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div id="pruvodce" class="bg-gradient-to-br from-white to-yellow-50 rounded-3xl p-12 border border-yellow-100 shadow-xl">
        <div class="text-center mb-12">
          <div class="flex items-center justify-center rounded-full bg-gradient-to-r from-yellow-100 to-amber-100 w-20 h-20 mx-auto mb-6">
            <span class="text-3xl">🎯</span>
          </div>
          <h4 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
            👑 Jak vybrat ten správný zlatý ETF?
          </h4>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Praktický průvodce výběrem nejlepšího zlatého ETF podle vaší investiční strategie a preferencí rizika
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-white rounded-xl p-6 shadow-sm border border-yellow-100 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-center w-12 h-12 bg-yellow-100 rounded-xl mb-4">
              <span class="text-xl">🏆</span>
            </div>
            <h5 class="text-lg font-bold text-gray-900 mb-3">Fyzické vs syntetické</h5>
            <p class="text-gray-600 text-sm leading-relaxed">
              Fyzicky zajištěné ETF vlastní skutečné zlato (bezpečnější).
              Syntetické ETF používají deriváty (nižší náklady, vyšší riziko protistran).
            </p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm border border-amber-100 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-center w-12 h-12 bg-amber-100 rounded-xl mb-4">
              <span class="text-xl">💰</span>
            </div>
            <h5 class="text-lg font-bold text-gray-900 mb-3">TER a poplatky</h5>
            <p class="text-gray-600 text-sm leading-relaxed">
              Zlaté ETF mají TER 0,12-0,65%. iShares SGLD (0,25%) má nejlepší poměr
              velikost/náklady. Pozor na skladovací poplatky fyzického zlata.
            </p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm border border-orange-100 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-center w-12 h-12 bg-orange-100 rounded-xl mb-4">
              <span class="text-xl">📊</span>
            </div>
            <h5 class="text-lg font-bold text-gray-900 mb-3">Úložiště a audit</h5>
            <p class="text-gray-600 text-sm leading-relaxed">
              Kontrolujte kde je zlato uloženo (LBMA trezory v Londýně)
              a častost auditů. Transparentnost je klíčová u fyzických ETF.
            </p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm border border-yellow-100 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-center w-12 h-12 bg-yellow-100 rounded-xl mb-4">
              <span class="text-xl">🌍</span>
            </div>
            <h5 class="text-lg font-bold text-gray-900 mb-3">Měnové zajištění</h5>
            <p class="text-gray-600 text-sm leading-relaxed">
              Zlato je denominováno v USD. EUR hedged verze (Xtrackers 4GLD)
              eliminují měnové riziko pro české investory.
            </p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm border border-amber-100 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-center w-12 h-12 bg-amber-100 rounded-xl mb-4">
              <span class="text-xl">📈</span>
            </div>
            <h5 class="text-lg font-bold text-gray-900 mb-3">Likvidita a spready</h5>
            <p class="text-gray-600 text-sm leading-relaxed">
              Větší zlaté ETF mají užší bid-ask spready a lepší likviditu.
              iShares SGLD (15,7 mld.) má nejlepší obchodní podmínky.
            </p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-center w-12 h-12 bg-gray-100 rounded-xl mb-4">
              <span class="text-xl">🏅</span>
            </div>
            <h5 class="text-lg font-bold text-gray-900 mb-3">Daňové dopady</h5>
            <p class="text-gray-600 text-sm leading-relaxed">
              ETC struktura (Exchange Traded Commodity) má jiné daňové zacházení než ETF.
              Konzultujte s daňovým poradcem podle vaší situace.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">Často kladené otázky</h2>
        <p class="text-xl text-gray-600">Odpovědi na nejčastější dotazy o zlaté ETF</p>
      </div>

      <div class="space-y-6">
        <details class="group border border-gray-200 rounded-lg hover:border-yellow-200 transition-colors">
          <summary class="flex justify-between items-center w-full px-6 py-4 text-left bg-gray-50 cursor-pointer hover:bg-yellow-50 rounded-lg group-open:rounded-b-none transition-colors">
            <span class="font-semibold text-lg text-gray-900 group-hover:text-yellow-800">Jaké jsou nejlepší zlaté ETF v roce 2026?</span>
            <svg class="w-5 h-5 text-gray-500 group-hover:text-yellow-600 transition-all group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 py-4 text-gray-700 leading-relaxed bg-white rounded-b-lg">
            Nejlepší zlaté ETF jsou: <strong>iShares Physical Gold ETC</strong> (IE00B4ND3602)
            největší fyzicky zajištěný zlatý ETF s 15,7 mld. EUR, <strong>Xtrackers Physical Gold ETC EUR Hedged</strong> (DE000A1E0HR8)
            s 8,2 mld. EUR a EUR hedgingem, a <strong>WisdomTree Physical Gold ETC</strong>
            (JE00B1VS3333) s 7,8 mld. EUR a TER 0,39%.
          </div>
        </details>

        <details class="group border border-gray-200 rounded-lg hover:border-yellow-200 transition-colors">
