      "name": "Amundi MSCI Robotics & AI UCITS ETF Acc",
      "identifier": "LU1861132840"
    },
    {
      "@type": "FinancialProduct",
      "name": "L&G ROBO Global Robotics and Automation UCITS ETF",
      "identifier": "IE00BMW3QX54"
    }
  ],
  "mentions": [
