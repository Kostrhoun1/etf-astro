---
import Layout from '../../layouts/Layout.astro';
import InternalLinking from '../../components/InternalLinking.astro';
import Top3ETF from '../../components/etf/Top3ETF.astro';
import Top10Sections from '../../components/etf/Top10Sections.astro';
import { getTopETFsForCategory, categoryConfigs } from '../../lib/etf-data';

const config = categoryConfigs['nejlepsi-etf-2026'];
const etfs = await getTopETFsForCategory(config);
const currentYear = new Date().getFullYear();
const currentDate = new Date().toLocaleDateString('cs-CZ', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
const lastModified = new Date().toISOString();

// Enhanced Article Schema with E-E-A-T
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": `Nejlepší ETF 2026 - Top 3 doporučení pro české investory`,
  "description": `Kompletní srovnání nejlepších ETF fondů pro rok 2026. CSPX, IWDA, VWCE - poplatky TER, výnosy, velikost fondů.`,
  "image": "https://www.etfpruvodce.cz/og-best-etf-2026.jpg",
  "author": {
    "@type": "Person",
    "name": "Tomáš Kostrhoun",
    "url": "https://www.etfpruvodce.cz/o-nas"
  },
  "publisher": {
    "@type": "Organization",
    "name": "ETF průvodce.cz",
    "logo": {
      "@type": "ImageObject",
      "url": "https://www.etfpruvodce.cz/logo.png"
    }
  },
  "datePublished": `2026-01-01`,
  "dateModified": lastModified,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://www.etfpruvodce.cz/nejlepsi-etf/nejlepsi-etf-2026"
  },
  "articleSection": "Investment Guides",
  "keywords": `nejlepší ETF 2026, CSPX, IWDA, VWCE, ETF fondy, investování`,
  "wordCount": 2800,
  "inLanguage": "cs-CZ"
};

// FAQ Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `Jaké jsou nejlepší ETF fondy pro rok 2026?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Pro rok 2026 doporučujeme ${etfs[0]?.name || 'CSPX'}, ${etfs[1]?.name || 'IWDA'} a ${etfs[2]?.name || 'VWCE'}. Tyto ETF nabízejí optimální poměr nákladů, výkonnosti a rizika.`
      }
    },
    {
      "@type": "Question",
      "name": "Který ETF má nejnižší poplatky TER?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nejlevnější ETF mají TER poplatky od 0.03%. Mezi nejoblíbenější patří CSPX s TER 0.07%, IWDA s TER 0.20% a VWCE s TER 0.22%."
      }
    },
    {
      "@type": "Question",
      "name": "Je lepší investovat do jednoho ETF nebo více ETF?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Pro začátečníky doporučujeme jeden globální ETF jako VWCE. Pokročilejší investoři mohou kombinovat regionální ETF pro lepší kontrolu alokace."
      }
    },
    {
      "@type": "Question",
      "name": "Jak často bych měl investovat do ETF?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Doporučujeme pravidelné měsíční investování (DCA - Dollar Cost Averaging). Tato strategie snižuje riziko špatného načasování trhu a buduje disciplínu. Investujte částku, kterou si můžete dovolit dlouhodobě."
      }
    },
    {
      "@type": "Question",
      "name": "Jaký je rozdíl mezi akumulačním a distribučním ETF?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Akumulační ETF (Acc) automaticky reinvestují dividendy zpět do fondu, což je daňově výhodnější v ČR. Distribuční ETF (Dist) vyplácejí dividendy na účet. Pro dlouhodobé investování doporučujeme akumulační varianty."
      }
    },
    {
      "@type": "Question",
      "name": "Kde mohu koupit ETF fondy v České republice?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "ETF můžete koupit u brokerů jako XTB, Trading212, Degiro, Interactive Brokers, Portu nebo Fio e-Broker. Porovnejte si poplatky za obchodování, správu účtu a dostupné ETF před výběrem brokera."
      }
    }
  ]
};

// Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Domů",
      "item": "https://www.etfpruvodce.cz"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Nejlepší ETF",
      "item": "https://www.etfpruvodce.cz/nejlepsi-etf"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": `Nejlepší ETF 2026`,
      "item": "https://www.etfpruvodce.cz/nejlepsi-etf/nejlepsi-etf-2026"
    }
  ]
};

const relatedLinks = [
  { title: "Nejlepší S&P 500 ETF", href: "/nejlepsi-etf/nejlepsi-sp500-etf", description: "Srovnání amerických indexových fondů" },
  { title: "Nejlepší MSCI World ETF", href: "/nejlepsi-etf/nejlepsi-msci-world-etf", description: "Globální ETF pro vyspělé trhy" },
  { title: "Nejlepší dividendové ETF", href: "/nejlepsi-etf/nejlepsi-dividendove-etf", description: "ETF s výplatou dividend" },
  { title: "Srovnání ETF", href: "/srovnani-etf", description: "Interaktivní nástroj pro porovnání" },
  { title: "Kde koupit ETF", href: "/kde-koupit-etf", description: "Přehled brokerů a platforem" }
];

const stats = [
  { title: "Nejnižší náklady", value: "0.03% TER", description: "Nejlevnější ETF dostupné v Evropě", color: "green" },
  { title: "Globální pokrytí", value: "3,800+ firem", description: "Diverzifikace po celém světě", color: "blue" },
  { title: "Největší fondy", value: "95B+ EUR", description: "Nejvyšší likvidita a stabilita", color: "purple" },
  { title: "Dlouhodobý růst", value: "9%+ ročně", description: "Historický průměrný výnos", color: "indigo" }
];

const guides = [
  {
    title: "Pro začátečníky",
    icon: "👥",
    color: "green",
    recommendations: [
      "VWCE - vše v jednom ETF",
      "Pravidelné investování měsíčně",
      "Držení 10+ let",
      "Ignorování krátkodobých výkyvů"
    ]
  },
  {
    title: "Pro pokročilé",
    icon: "🏢",
    color: "blue",
    recommendations: [
      "Kombinace CSPX + IWDA",
      "5-10% rozvíjející se trhy",
      "Rebalancing jednou ročně",
      "Sledování TER a velikosti"
    ]
  },
  {
    title: "Pro experty",
    icon: "🚀",
    color: "purple",
    recommendations: [
      "Regionální + sektorové ETF",
      "Taktická alokace aktiv",
      "Využití momentum efektů",
      "Optimalizace daní"
    ]
  }
];
---

<Layout
  title={`Nejlepší ETF 2026 - CSPX vs IWDA vs VWCE`}
  description={`Top 3 nejlepší ETF fondy pro rok 2026. CSPX, IWDA, VWCE - srovnání poplatků TER, výnosů, velikosti fondů. Aktuální data k ${currentDate}.`}
  canonical="/nejlepsi-etf/nejlepsi-etf-2026"
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Modern Hero Section -->
  <section class="relative py-16 md:py-24 bg-gradient-to-br from-gray-50 to-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-blue-50/50 via-indigo-50/30 to-purple-50/50"></div>
    <div class="absolute top-20 left-1/4 w-72 h-72 bg-gradient-to-br from-blue-200 to-indigo-200 rounded-full mix-blend-multiply filter blur-xl opacity-30"></div>
    <div class="absolute top-40 right-1/4 w-72 h-72 bg-gradient-to-br from-indigo-200 to-purple-200 rounded-full mix-blend-multiply filter blur-xl opacity-30"></div>
    <div class="absolute bottom-20 left-1/3 w-72 h-72 bg-gradient-to-br from-purple-200 to-pink-200 rounded-full mix-blend-multiply filter blur-xl opacity-30"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center w-full">

        <!-- Left Content -->
        <div class="space-y-8">
          <div class="inline-flex items-center bg-gradient-to-r from-blue-100 to-indigo-100 text-blue-700 px-6 py-3 rounded-full text-sm font-medium backdrop-blur-sm border border-blue-200/50">
            🚩 Aktuální k {currentDate}
          </div>

          <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 leading-tight">
            Nejlepší
            <span class="bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 bg-clip-text text-transparent">
              ETF {currentYear}
            </span>
          </h1>

          <!-- Author byline - E-E-A-T signal -->
          <div class="flex flex-wrap items-center gap-2 text-sm text-gray-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400">
              <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
            <span>Autor: </span>
            <a href="/o-nas" class="text-violet-600 hover:text-violet-700 font-medium hover:underline">
              Tomáš Kostrhoun
            </a>
            <span class="text-gray-400">|</span>
            <span>Aktualizováno: {new Date().toLocaleDateString('cs-CZ')}</span>
          </div>

          <p class="text-xl text-gray-600 leading-relaxed max-w-2xl">
            Kompletní srovnání nejlepších ETF fondů pro rok {currentYear}.
            Analýza poplatků, výkonnosti a praktické tipy pro český trh.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="#top3"
              class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white px-8 py-3 text-lg font-semibold shadow-lg hover:shadow-xl transition-all rounded-lg"
            >
              ⭐ Top 3 doporučení
            </a>
            <a
              href="#srovnani"
              class="inline-flex items-center justify-center gap-2 border-2 border-gray-300 text-gray-700 hover:bg-gray-50 px-8 py-3 text-lg font-semibold rounded-lg transition-colors"
            >
              📊 Srovnání ETF
            </a>
          </div>
        </div>

        <!-- Right Content - Stats Grid -->
        <div class="grid grid-cols-2 gap-6 lg:gap-8">
          {stats.map((stat) => (
            <div class="bg-white rounded-lg p-6 shadow hover:shadow-md transition-shadow group">
              <div class={`flex items-center justify-center rounded-full w-16 h-16 mx-auto mb-6 group-hover:scale-110 transition-transform ${
                stat.color === 'green' ? 'bg-gradient-to-r from-green-500 to-emerald-500' :
                stat.color === 'blue' ? 'bg-gradient-to-r from-blue-500 to-cyan-500' :
                stat.color === 'purple' ? 'bg-gradient-to-r from-purple-500 to-violet-500' :
                'bg-gradient-to-r from-indigo-500 to-blue-500'
              }`}>
                <span class="text-2xl text-white">
                  {stat.color === 'green' ? '💰' : stat.color === 'blue' ? '🌍' : stat.color === 'purple' ? '🛡️' : '📈'}
                </span>
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-3 text-center group-hover:text-blue-800 transition-colors">
                {stat.title}
              </h3>
              <p class="text-2xl font-bold text-center mb-2 bg-gradient-to-r from-gray-700 to-gray-900 bg-clip-text text-transparent">
                {stat.value}
              </p>
              <p class="text-gray-600 leading-relaxed text-center text-sm">
                {stat.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Top 3 Recommendations -->
  <section id="top3" class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Top 3 nejlepší ETF {currentYear}
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Naše doporučení nejlepších ETF fondů pro rok {currentYear} na základě analýzy {etfs.length} fondů
        </p>
      </div>

      <Top3ETF etfs={etfs} currency="EUR" />
    </div>
  </section>

  <!-- Full Comparison Table -->
  <section id="srovnani" class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Top10Sections etfs={etfs} currency="EUR" categoryName="ETF 2026" />
    </div>
  </section>

  <!-- Selection Guide Section -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div id="pruvodce" class="bg-gradient-to-br from-white to-blue-50 rounded-3xl p-12 border border-blue-100 shadow-xl">
        <div class="text-center mb-12">
          <div class="flex items-center justify-center rounded-full bg-gradient-to-r from-blue-100 to-indigo-100 w-20 h-20 mx-auto mb-6">
            <span class="text-4xl">🎯</span>
          </div>
          <h3 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
            Jak vybrat nejlepší ETF pro rok {currentYear}?
          </h3>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">
            Praktický průvodce výběrem podle vašeho investičního profilu
          </p>
        </div>

        <div class="grid lg:grid-cols-3 gap-8">
          {guides.map((guide) => (
            <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-lg hover:shadow-xl transition-shadow">
              <div class={`w-16 h-16 rounded-full flex items-center justify-center mb-6 mx-auto ${
                guide.color === 'green' ? 'bg-gradient-to-r from-green-500 to-emerald-600' :
                guide.color === 'blue' ? 'bg-gradient-to-r from-blue-500 to-indigo-600' :
                'bg-gradient-to-r from-purple-500 to-violet-600'
              }`}>
                <span class="text-2xl">{guide.icon}</span>
              </div>
              <h4 class="text-xl font-bold text-gray-900 text-center mb-6">{guide.title}</h4>
              <ul class="space-y-3">
                {guide.recommendations.map((rec) => (
                  <li class="flex items-start gap-3">
                    <div class="w-2 h-2 rounded-full bg-blue-500 mt-2 flex-shrink-0"></div>
                    <span class="text-gray-700">{rec}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Internal Linking -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <InternalLinking links={relatedLinks} title="Související články" />
  </div>
</Layout>
