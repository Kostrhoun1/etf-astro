---
import Layout from '../../layouts/Layout.astro';
import ETFTable from '../../components/ETFTable.astro';
import InternalLinking from '../../components/InternalLinking.astro';
import Top3ETF from '../../components/etf/Top3ETF.astro';
import Top10Sections from '../../components/etf/Top10Sections.astro';
import { getTopETFsForCategory, categoryConfigs } from '../../lib/etf-data';

const config = categoryConfigs['nejlepsi-defense-etf'];
const etfs = await getTopETFsForCategory(config);
const currentYear = new Date().getFullYear();
const lastModified = new Date().toISOString().split('T')[0];

const defenseFaqData = [
  {
    question: "Který Defense ETF je nejlepší pro rok 2026?",
    answer: "Naše TOP 3 doporučení: VanEck Defense UCITS ETF (DFEN, IE000YYE6WK5) s největšími aktivy 6,38 mld. EUR, WisdomTree Europe Defence ETF (DEFN, IE0002Y8CX98) s 3,40 mld. EUR pro evropskou expozici, a HANetf Future of Defence ETF (NATO, IE000OJ5TQP4) s 2,59 mld. EUR zaměřený na budoucí vojenské technologie."
  },
  {
    question: "Jaké jsou výhody investování do Defense ETF?",
    answer: "Defense ETF nabízejí expozici k defenzivnímu a strategicky důležitému sektoru. Výhody zahrnují: stabilní vládní kontrakty, dlouhodobé investiční cykly, technologické inovace v aerospace a rosnoucí geopolitické napětí zvyšující poptávku po obraně."
  },
  {
    question: "Obsahují Defense ETF i civilní aerospace společnosti?",
    answer: "Ano, kvalitní Defense ETF obvykle obsahují mix čistě obranných společností (Lockheed Martin, Northrop Grumman) i civilních aerospace firem (Boeing, Airbus). Tato diversifikace snižuje závislost pouze na vojenských zakázkách."
  },
  {
    question: "Jaké jsou poplatky u Defense ETF?",
    answer: "Poplatky (TER) u Defense ETF se pohybují mezi 0,35-0,55% ročně. iShares Global Aerospace & Defence má nejnižší TER 0,35%, WisdomTree Europe Defence 0,40% a VanEck Defense 0,55%. Specializované ETF mají vyšší poplatky než široké indexy."
  },
  {
    question: "Jsou Defense ETF etické pro investování?",
    answer: "Defense ETF investují do společností vyrábějících obranné technologie pro legitímní národní obranu. Mnoho investorů je považuje za etické, protože podporují bezpečnost demokratických zemí. Rozhodnutí je však individuální podle osobních hodnot."
  },
  {
    question: "Kde koupit naše doporučené Defense ETF?",
    answer: "Naše TOP 3 Defense ETF můžete koupit u většiny českých brokerů. VanEck Defense (IE000YYE6WK5) a WisdomTree Europe Defence (IE0002Y8CX98) jsou dostupné zdarma na Degiro. HANetf Future of Defence (IE000OJ5TQP4) najdete u Interactive Brokers, XTB nebo Trading212."
  }
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Nejlepší Defense ETF 2026 | Srovnání a Doporučení",
  "description": "Kompletní průvodce nejlepšími Defense ETF pro rok 2026. Srovnání výkonnosti, poplatků a držených aktiv.",
  "author": {
    "@type": "Person",
    "name": "Tomáš Kostrhoun",
    "url": "https://etfpruvodce.cz/o-nas#tomas-kostrhoun"
  },
  "publisher": {
    "@type": "Organization",
    "name": "ETF průvodce.cz",
    "logo": {
      "@type": "ImageObject",
      "url": "https://etfpruvodce.cz/logo.png"
    }
  },
  "datePublished": "2025-12-15",
  "dateModified": lastModified,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://etfpruvodce.cz/nejlepsi-etf/nejlepsi-defense-etf"
  },
  "image": "https://etfpruvodce.cz/og-defense-etf.jpg"
};

// FAQ structured data for better search snippets
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": defenseFaqData.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};

// Breadcrumb structured data
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Domů",
      "item": "https://etfpruvodce.cz"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Nejlepší ETF",
      "item": "https://etfpruvodce.cz/nejlepsi-etf"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Nejlepší defense ETF",
      "item": "https://etfpruvodce.cz/nejlepsi-etf/nejlepsi-defense-etf"
    }
  ]
};

const relatedLinks = [
  { title: "Nejlepší Kyberbezpečnost ETF 2026", href: "/nejlepsi-etf/nejlepsi-kyberbezpecnost-etf", description: "Investice do kybernetické bezpečnosti a defense technologií", icon: "🔐" },
  { title: "Nejlepší AI ETF 2026", href: "/nejlepsi-etf/nejlepsi-ai-etf", description: "ETF zaměřené na umělou inteligenci a vojenské AI systémy", icon: "🤖" },
  { title: "Nejlepší Tech ETF 2026", href: "/nejlepsi-etf/nejlepsi-technologicke-etf", description: "Širší technologický sektor včetně defense tech", icon: "💻" }
];
---

<Layout
  title={`Nejlepší Defense ETF 2026 | Srovnání a Doporučení`}
  description="Najděte nejlepší Defense ETF pro rok 2026. Srovnání výkonnosti, poplatků a držených aktiv. Investujte do obranného průmyslu budoucnosti."
  canonical={'/nejlepsi-etf/' + config.slug}
>
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Hero Section -->
  <section class="relative py-16 md:py-24 bg-gradient-to-br from-gray-50 to-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-gray-50/50 via-blue-50/30 to-slate-50/50"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center w-full">

        <!-- Left Content -->
        <div class="space-y-8">
          <div class="inline-flex items-center bg-gradient-to-r from-gray-100 to-blue-100 text-gray-700 px-6 py-3 rounded-full text-sm font-medium backdrop-blur-sm border border-gray-200/50">
            🛡️ Aktuální k {new Date().toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' })}
          </div>

          <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 leading-tight">
            Nejlepší{' '}
            <span class="bg-gradient-to-r from-gray-600 via-blue-600 to-slate-600 bg-clip-text text-transparent">
              Defense ETF
            </span>
          </h1>

          <!-- Author byline - E-E-A-T signal -->
          <div class="flex flex-wrap items-center gap-2 text-sm text-gray-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400">
              <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
            <span>Autor: </span>
            <a href="/o-nas" class="text-violet-600 hover:text-violet-700 font-medium hover:underline">
              Tomáš Kostrhoun
            </a>
            <span class="text-gray-400">•</span>
            <span>
              Aktualizováno: {new Date(lastModified).toLocaleDateString('cs-CZ', { day: 'numeric', month: 'numeric', year: 'numeric' })}
            </span>
          </div>

          <p class="text-xl text-gray-600 leading-relaxed max-w-2xl">
            Kompletní srovnání nejlepších Defense ETF fondů pro investice do obranného průmyslu.
            Analýza poplatků, výkonnosti a praktické tipy pro výběr.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#top3" class="inline-flex items-center justify-center bg-gradient-to-r from-gray-600 to-blue-600 hover:from-gray-700 hover:to-blue-700 text-white px-8 py-3 text-lg font-semibold shadow-lg hover:shadow-xl transition-all rounded-md h-12">
              🛡️ Top 3 doporučení
            </a>
            <a href="#srovnani" class="inline-flex items-center justify-center border-2 border-gray-300 text-gray-700 hover:bg-gray-50 px-8 py-3 text-lg font-semibold h-12 rounded-md">
              📊 Srovnání ETF
            </a>
          </div>
        </div>

        <!-- Right Content - Defense Stats -->
        <div class="relative mt-12">
          <div class="bg-white rounded-2xl p-6 border border-gray-300 shadow-lg">

            <!-- Simple Header -->
            <div class="text-center mb-6">
              <div class="inline-flex items-center justify-center w-12 h-12 bg-gray-100 rounded-xl mb-3">
                <span class="text-2xl">🛡️</span>
              </div>
              <h3 class="text-lg font-semibold text-gray-800 mb-1">
                Defense sektor v číslech
              </h3>
              <p class="text-sm text-gray-600">Klíčová fakta o obranném průmyslu</p>
            </div>

            <!-- Stats Grid -->
            <div class="grid grid-cols-2 gap-3 mb-6">
              <div class="bg-white rounded-lg p-4 border border-gray-200 hover:border-gray-300 transition-colors">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-gray-600">🏢</span>
                  <span class="text-xs text-gray-500 font-medium">VLADNI ROZPOCTY</span>
                </div>
                <div class="text-2xl font-bold text-gray-900">$600B+</div>
                <div class="text-xs text-gray-600">globalni defense vydaje</div>
              </div>

              <div class="bg-white rounded-lg p-4 border border-gray-200 hover:border-blue-200 transition-colors">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-blue-600">🌍</span>
                  <span class="text-xs text-gray-500 font-medium">KLICOVI HRACI</span>
                </div>
                <div class="text-2xl font-bold text-gray-900">NATO</div>
                <div class="text-xs text-gray-600">USA, EU zeme</div>
              </div>

              <div class="bg-white rounded-lg p-4 border border-gray-200 hover:border-slate-200 transition-colors">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-slate-600">⚔️</span>
                  <span class="text-xs text-gray-500 font-medium">DRIVER</span>
                </div>
                <div class="text-2xl font-bold text-gray-900">Geopolitika</div>
                <div class="text-xs text-gray-600">globalni napeti</div>
              </div>

              <div class="bg-white rounded-lg p-4 border border-gray-200 hover:border-gray-300 transition-colors">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-gray-600">📋</span>
                  <span class="text-xs text-gray-500 font-medium">CHARAKTER</span>
                </div>
                <div class="text-2xl font-bold text-gray-900">Stabilni</div>
                <div class="text-xs text-gray-600">vladni kontrakty</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Introduction Section -->
  <section id="uvod" class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <div class="flex items-center justify-center rounded-full bg-gray-100 w-20 h-20 mx-auto mb-8 hover:bg-gray-200 transition-colors">
          <span class="text-4xl">🛡️</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          Co jsou Defense ETF?
        </h2>
        <p class="text-xl md:text-2xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
          Investiční fondy zaměřené na obranný průmysl a aerospace společnosti poskytující národní bezpečnost
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
        <div class="border-transparent shadow-none hover:shadow-md transition-shadow duration-200 group bg-white rounded-lg p-6">
          <div class="flex items-center justify-center rounded-full bg-gradient-to-r from-gray-500 to-slate-600 w-16 h-16 mx-auto mb-6 group-hover:scale-110 transition-transform">
            <span class="text-2xl">🛡️</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3 text-center group-hover:text-gray-800 transition-colors">
            Obranné technologie
          </h3>
          <p class="text-gray-600 leading-relaxed text-center">
            ETF investují do společností vyvíjejících vojenské systémy, radary, rakety a pokročilé obranné technologie.
          </p>
        </div>

        <div class="border-transparent shadow-none hover:shadow-md transition-shadow duration-200 group bg-white rounded-lg p-6">
          <div class="flex items-center justify-center rounded-full bg-gradient-to-r from-blue-500 to-violet-600 w-16 h-16 mx-auto mb-6 group-hover:scale-110 transition-transform">
            <span class="text-2xl">✈️</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3 text-center group-hover:text-gray-800 transition-colors">
            Aerospace průmysl
          </h3>
          <p class="text-gray-600 leading-relaxed text-center">
            Zahrnují civilní i vojenské letectví - Boeing, Airbus, Lockheed Martin a další aerospace lídry.
          </p>
        </div>

        <div class="border-transparent shadow-none hover:shadow-md transition-shadow duration-200 group bg-white rounded-lg p-6">
          <div class="flex items-center justify-center rounded-full bg-gradient-to-r from-slate-500 to-gray-600 w-16 h-16 mx-auto mb-6 group-hover:scale-110 transition-transform">
            <span class="text-2xl">🏢</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3 text-center group-hover:text-gray-800 transition-colors">
            Stabilní kontrakty
          </h3>
          <p class="text-gray-600 leading-relaxed text-center">
            Dlouhodobé vládní zakázky poskytují předvídatelné příjmy a menší volatilitu než jiné tech sektory.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Top 3 Section -->
  <section id="top3" class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Top 3 ETF v této kategorii
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Naše doporučení na základě analýzy {etfs.length} ETF fondů
        </p>
      </div>
      <Top3ETF etfs={etfs} currency="EUR" />
    </div>
  </section>

  <!-- Top 10 Sections -->
  <Top10Sections etfs={etfs} currency="EUR" categoryName="defense" />

  <!-- Full ETF Table -->
  <section id="srovnani" class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ETFTable etfs={etfs} title={'TOP ' + config.title} />
    </div>
  </section>

  <!-- Selection Guide Section -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div id="pruvodce" class="bg-gradient-to-br from-white to-gray-50 rounded-3xl p-12 border border-gray-100 shadow-xl">
        <div class="text-center mb-12">
          <div class="flex items-center justify-center rounded-full bg-gradient-to-r from-gray-100 to-blue-100 w-20 h-20 mx-auto mb-6">
            <span class="text-4xl">🎯</span>
          </div>
          <h4 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
            💡 Jak vybrat ten správný Defense ETF?
          </h4>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Při výběru Defense ETF je důležité zvážit geografickou expozici, mix obranných vs. civilních aerospace společností
            a poměr mezi tradičními a high-tech defense firmami.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
          <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100">
            <div class="w-12 h-12 bg-gray-100 rounded-xl flex items-center justify-center mb-6">
              <span class="text-xl">📊</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Technické faktory</h3>
            <ul class="space-y-3 text-gray-600">
              <li class="flex items-start gap-3">
                <div class="w-1.5 h-1.5 bg-gray-400 rounded-full mt-2 flex-shrink-0"></div>
                <span><strong>Velikost aktiv:</strong> Min. 500 mil. EUR</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-1.5 h-1.5 bg-gray-400 rounded-full mt-2 flex-shrink-0"></div>
                <span><strong>TER poplatky:</strong> Obvykle 0,35-0,55%</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-1.5 h-1.5 bg-gray-400 rounded-full mt-2 flex-shrink-0"></div>
                <span><strong>Geografická expozice:</strong> US vs. evropská</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-1.5 h-1.5 bg-gray-400 rounded-full mt-2 flex-shrink-0"></div>
                <span><strong>Likvidita:</strong> Denní obchodování</span>
              </li>
            </ul>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100">
            <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-6">
              <span class="text-xl">🎯</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Portfolio faktory</h3>
            <ul class="space-y-3 text-gray-600">
              <li class="flex items-start gap-3">
                <div class="w-1.5 h-1.5 bg-blue-400 rounded-full mt-2 flex-shrink-0"></div>
                <span><strong>Defense vs. Aerospace:</strong> Poměr segmentů</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-1.5 h-1.5 bg-blue-400 rounded-full mt-2 flex-shrink-0"></div>
                <span><strong>Top holdings:</strong> Kvalita lídrů trhu</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-1.5 h-1.5 bg-blue-400 rounded-full mt-2 flex-shrink-0"></div>
                <span><strong>Kontraktová stabilita:</strong> Vládní vs. komerční</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-1.5 h-1.5 bg-blue-400 rounded-full mt-2 flex-shrink-0"></div>
                <span><strong>Technologický fokus:</strong> Tradiční vs. high-tech</span>
              </li>
            </ul>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100">
            <div class="w-12 h-12 bg-cyan-100 rounded-xl flex items-center justify-center mb-6">
              <span class="text-xl">🏆</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Praktické tipy</h3>
            <ul class="space-y-3 text-gray-600">
              <li class="flex items-start gap-3">
                <div class="w-1.5 h-1.5 bg-cyan-400 rounded-full mt-2 flex-shrink-0"></div>
                <span><strong>Začněte s velkými:</strong> DFEN nebo DEFN</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-1.5 h-1.5 bg-cyan-400 rounded-full mt-2 flex-shrink-0"></div>
                <span><strong>Diverzifikace:</strong> Kombinujte US a EU</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-1.5 h-1.5 bg-cyan-400 rounded-full mt-2 flex-shrink-0"></div>
                <span><strong>Dlouhodobě:</strong> 5+ let horizon</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-1.5 h-1.5 bg-cyan-400 rounded-full mt-2 flex-shrink-0"></div>
                <span><strong>Monitorujte:</strong> Geopolitické trendy</span>
              </li>
            </ul>
          </div>
        </div>

        <div class="bg-gradient-to-r from-gray-600 to-blue-600 text-white rounded-2xl p-8">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center">
              <span class="text-2xl">🚀</span>
            </div>
            <div>
              <h3 class="text-2xl font-bold">Tip pro začátečníky</h3>
              <p class="text-gray-100">Strategické investování do obrany</p>
            </div>
          </div>
          <p class="text-lg leading-relaxed">
            Začněte s největšími defense ETF jako <strong>VanEck Defense ETF</strong>
            nebo <strong>WisdomTree Europe Defence ETF</strong>. Defense sektor je cyklický,
            ale má stabilní dlouhodobé trendy díky geopolitickým faktorům a kontinuálním vládním investicím.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gradient-to-br from-gray-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h3 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          Často kladené otázky o <span class="bg-gradient-to-r from-gray-600 to-blue-600 bg-clip-text text-transparent">Defense ETF</span>
        </h3>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Odpovědi na nejčastější dotazy ohledně investování do Defense ETF a obranného průmyslu
        </p>
      </div>

      <div class="max-w-4xl mx-auto space-y-6">
        {defenseFaqData.map((faq, index) => (
          <details class="group border border-gray-200 rounded-lg hover:border-gray-300 transition-colors">
            <summary class="flex justify-between items-center w-full px-6 py-4 text-left bg-gray-50 cursor-pointer hover:bg-gray-100 rounded-lg group-open:rounded-b-none transition-colors">
              <span class="font-semibold text-lg text-gray-900 group-hover:text-gray-800 flex items-start gap-3">
                <span class="w-6 h-6 bg-gradient-to-r from-gray-500 to-blue-500 rounded-full flex items-center justify-center text-white text-sm font-bold flex-shrink-0 mt-0.5">
                  {index + 1}
                </span>
                {faq.question}
              </span>
              <svg class="w-5 h-5 text-gray-500 group-hover:text-gray-600 transition-all group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 py-4 text-gray-700 leading-relaxed bg-white rounded-b-lg ml-9">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-br from-gray-900 via-blue-900 to-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="bg-white/10 backdrop-blur rounded-3xl p-12 border border-white/20">
        <h3 class="text-4xl md:text-5xl font-bold text-white mb-6">
          Připraveni investovat do
          <span class="bg-gradient-to-r from-blue-400 to-cyan-300 bg-clip-text text-transparent"> Defense ETF</span>?
        </h3>
        <p class="text-xl text-blue-100 mb-8 max-w-3xl mx-auto">
          Začněte s našimi doporučenými Defense ETF a získejte expozici k strategicky důležitému obranému průmyslu s dlouhodobým růstovým potenciálem.
        </p>

        <div class="flex flex-col sm:flex-row gap-6 justify-center">
          <a href="#top3" class="inline-flex items-center justify-center bg-blue-600 hover:bg-blue-700 text-white px-8 py-4 text-lg font-semibold rounded-full transition-all duration-300 hover:scale-105">
            🛡️ Zobrazit TOP Defense ETF
          </a>
          <a href="/srovnani-brokeru" class="inline-flex items-center justify-center border-2 border-blue-400 text-blue-100 hover:bg-blue-500/20 px-8 py-4 text-lg font-semibold rounded-full backdrop-blur">
            👥 Najít brokera
          </a>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <InternalLinking links={relatedLinks} title="Související články" />
  </div>
</Layout>
