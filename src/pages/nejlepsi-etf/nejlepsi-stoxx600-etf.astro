---
import Layout from '../../layouts/Layout.astro';
import ETFTable from '../../components/ETFTable.astro';
import InternalLinking from '../../components/InternalLinking.astro';
import Top3ETF from '../../components/etf/Top3ETF.astro';
import Top10Sections from '../../components/etf/Top10Sections.astro';
import { getTopETFsForCategory, categoryConfigs } from '../../lib/etf-data';

const config = categoryConfigs['nejlepsi-stoxx600-etf'];
const etfs = await getTopETFsForCategory(config);
const currentYear = new Date().getFullYear();
const lastModified = new Date().toISOString().split('T')[0];
const currentDate = new Date().toLocaleDateString('cs-CZ', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": `Nejlepší STOXX 600 ETF ${currentYear} - LYP6 vs EXSA vs XESC`,
  "description": `Srovnání nejlepších STOXX 600 ETF ${currentYear}. LYP6, EXSA, XESC - poplatky TER, výnosy, velikost fondů.`,
  "image": "https://www.etfpruvodce.cz/og-stoxx600-etf.jpg",
  "author": {
    "@type": "Person",
    "name": "Tomáš Kostrhoun",
    "url": "https://www.etfpruvodce.cz/o-nas#tomas-kostrhoun"
  },
  "publisher": {
    "@type": "Organization",
    "name": "ETF průvodce.cz",
    "logo": {
      "@type": "ImageObject",
      "url": "https://www.etfpruvodce.cz/logo.png"
    }
  },
  "datePublished": `${currentYear}-01-15`,
  "dateModified": lastModified,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://www.etfpruvodce.cz/nejlepsi-etf/nejlepsi-stoxx600-etf"
  },
  "articleSection": "Investment Guides",
  "keywords": "nejlepší STOXX 600 ETF, LYP6 ETF, EXSA ETF, XESC ETF, STOXX Europe 600, evropské ETF fondy",
  "inLanguage": "cs-CZ"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Jak jste vybrali TOP 3 STOXX 600 ETF?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Výběr je založen na kombinaci faktorů: nejnižší poplatky TER, velikost fondu, likvidita, tracking error a celková kvalita providera. Data čerpáme z naší databáze a aktualizujeme měsíčně."
      }
    },
    {
      "@type": "Question",
      "name": "Co znamenají TOP 10 žebříčky na této stránce?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Žebříčky ukazují nejlepší STOXX 600 ETF podle různých kritérií - nejnižší poplatky, největší velikost fondu a nejvyšší výnosy za poslední rok. Data jsou živá z naší databáze."
      }
    },
    {
      "@type": "Question",
      "name": "Proč se některé STOXX 600 ETF neobjevují v seznamech?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Odfiltrováváme malé fondy (pod 100 mil EUR), pákové produkty, tematické a sektorové ETF. Zaměřujeme se pouze na kvalitní širokoevropské ETF sledující celý STOXX 600 index."
      }
    },
    {
      "@type": "Question",
      "name": "Akumulační vs distribuční STOXX 600 ETF?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Akumulační ETF automaticky reinvestují dividendy, což je ideální pro dlouhodobé spoření. Distribuční ETF vyplácejí dividendy v hotovosti, vhodné pro investory hledající pravidelný příjem."
      }
    },
    {
      "@type": "Question",
      "name": "Který STOXX 600 ETF má nejnižší náklady?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Podle aktuálních dat má nejnižší TER Amundi ETF. Kompletní žebříček najdete v sekci 'Top 10 podle nejnižších poplatků' s živými daty z naší databáze."
      }
    },
    {
      "@type": "Question",
      "name": "Jsou data na této stránce aktuální?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ano, všechna data o ETF (TER, velikost fondů, výnosy) se načítají živě z naší databáze a jsou aktualizována denně. Poslední aktualizace článku byla provedena na začátku tohoto měsíce."
      }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Domů",
      "item": "https://www.etfpruvodce.cz"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Nejlepší ETF",
      "item": "https://www.etfpruvodce.cz/nejlepsi-etf"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Nejlepší STOXX 600 ETF",
      "item": "https://www.etfpruvodce.cz/nejlepsi-etf/nejlepsi-stoxx600-etf"
    }
  ]
};

const relatedLinks = [
  { title: "Nejlepší evropské ETF", href: "/nejlepsi-etf/nejlepsi-evropske-etf", description: "Kompletní srovnání evropských ETF fondů", icon: "🇪🇺" },
  { title: "Nejlepší MSCI World ETF", href: "/nejlepsi-etf/nejlepsi-msci-world-etf", description: "Globální diverzifikace s MSCI World", icon: "🌍" },
  { title: "Kde koupit ETF", href: "/kde-koupit-etf", description: "Srovnání brokerů pro nákup ETF", icon: "🏦" },
  { title: "Portfolio strategie", href: "/portfolio-strategie", description: "Jak sestavit ETF portfolio", icon: "📊" }
];
---

<Layout
  title={`Nejlepší STOXX 600 ETF ${currentYear} - LYP6 vs EXSA vs XESC`}
  description={`Srovnání nejlepších STOXX 600 ETF ${currentYear}. LYP6, EXSA, XESC - poplatky TER, výnosy, velikost fondů. Kompletní analýza evropských ETF k ${currentDate}.`}
  canonical={'/nejlepsi-etf/' + config.slug}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Hero Section -->
  <section class="relative py-16 md:py-24 bg-gradient-to-br from-gray-50 to-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-purple-50/50 via-violet-50/30 to-blue-50/50"></div>

    <!-- Animated blobs -->

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center w-full">

        <!-- Left Content -->
        <div class="space-y-8">
          <div class="inline-flex items-center bg-gradient-to-r from-purple-100 to-violet-100 text-purple-700 px-6 py-3 rounded-full text-sm font-medium backdrop-blur-sm border border-purple-200/50">
            🇪🇺 Aktuální k {currentDate}
          </div>

          <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 leading-tight">
            Nejlepší <span class="bg-gradient-to-r from-purple-600 via-violet-600 to-blue-600 bg-clip-text text-transparent">STOXX 600 ETF</span>
          </h1>

          <!-- Author byline -->
          <div class="flex flex-wrap items-center gap-2 text-sm text-gray-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400">
              <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
            <span>Autor: </span>
            <a href="/o-nas" class="text-violet-600 hover:text-violet-700 font-medium hover:underline">Tomáš Kostrhoun</a>
            <span class="text-gray-400">•</span>
            <span>Aktualizováno: {new Date().toLocaleDateString('cs-CZ', { day: 'numeric', month: 'numeric', year: 'numeric' })}</span>
          </div>

          <p class="text-xl text-gray-600 leading-relaxed max-w-2xl">
            Kompletní srovnání nejlepších ETF fondů na STOXX Europe 600 index. Analýza poplatků, výnosů a praktické tipy pro výběr správného fondu.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#top3" class="inline-flex items-center justify-center bg-gradient-to-r from-purple-600 to-violet-600 hover:from-purple-700 hover:to-indigo-700 text-white px-8 py-3 text-lg font-semibold shadow-lg hover:shadow-xl transition-all rounded-md h-12">
              ⭐ Top 3 doporučení
            </a>
            <a href="#srovnani" class="inline-flex items-center justify-center border-2 border-gray-300 text-gray-700 hover:bg-gray-50 px-8 py-3 text-lg font-semibold h-12 rounded-md">
              📊 Srovnání všech
            </a>
          </div>
        </div>

        <!-- Right Content - Stats Box -->
        <div class="relative">
          <div class="relative bg-gradient-to-br from-white/80 to-gray-50/60 backdrop-blur-sm rounded-3xl p-8 shadow-2xl border border-white/20">
            <div class="text-center mb-8">
              <h3 class="text-2xl font-bold text-gray-900 mb-2">📊 STOXX 600 Stats</h3>
              <p class="text-gray-600">Klíčové informace o indexu</p>
            </div>

            <div class="grid grid-cols-2 gap-6 mb-6">
              <div class="text-center p-4 bg-gradient-to-r from-purple-50 to-violet-50 rounded-xl border border-purple-200">
                <div class="text-3xl font-bold text-purple-600 mb-1">600</div>
                <div class="text-sm text-gray-600">Evropských firem</div>
              </div>

              <div class="text-center p-4 bg-gradient-to-r from-violet-50 to-blue-50 rounded-xl border border-indigo-200">
                <div class="text-3xl font-bold text-violet-600 mb-1">~7%</div>
                <div class="text-sm text-gray-600">Ročně za 20 let</div>
              </div>

              <div class="text-center p-4 bg-gradient-to-r from-blue-50 to-cyan-50 rounded-xl border border-blue-200">
                <div class="text-3xl font-bold text-blue-600 mb-1">17</div>
                <div class="text-sm text-gray-600">Evropských zemí</div>
              </div>

              <div class="text-center p-4 bg-gradient-to-r from-cyan-50 to-violet-50 rounded-xl border border-cyan-200">
                <div class="text-3xl font-bold text-cyan-600 mb-1">{etfs.length}</div>
                <div class="text-sm text-gray-600">ETF na výběr</div>
              </div>
            </div>

            <div class="text-center pt-6 border-t border-gray-200/50">
              <p class="text-sm text-gray-600 mb-3">Nejširší evropský index</p>
              <a href="#pruvodce" class="inline-flex items-center justify-center border border-purple-200 text-purple-600 hover:bg-purple-50 px-4 py-2 rounded-md text-sm font-medium">
                Průvodce výběrem
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Introduction Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          Co je STOXX Europe 600?
        </h2>
        <p class="text-xl md:text-2xl text-gray-600 max-w-4xl mx-auto leading-relaxed">
          STOXX Europe 600 je klíčový index pokrývající 600 největších firem z 17 evropských zemí. Reprezentuje přibližně 90% tržní kapitalizace evropských akcií.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
        <div class="border-transparent shadow-none hover:shadow-md transition-shadow duration-200 group bg-white rounded-lg p-6">
          <div class="flex items-center justify-center rounded-full bg-gradient-to-r from-purple-500 to-violet-600 w-16 h-16 mx-auto mb-6 group-hover:scale-110 transition-transform text-2xl">
            👑
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3 text-center group-hover:text-purple-800 transition-colors">
            600 největších firem
          </h3>
          <p class="text-gray-600 leading-relaxed text-center">
            Index pokrývá nejkvalitnější evropské společnosti z různých sektorů a zemí pro maximální diverzifikaci.
          </p>
        </div>

        <div class="border-transparent shadow-none hover:shadow-md transition-shadow duration-200 group bg-white rounded-lg p-6">
          <div class="flex items-center justify-center rounded-full bg-gradient-to-r from-violet-500 to-blue-600 w-16 h-16 mx-auto mb-6 group-hover:scale-110 transition-transform text-2xl">
            📍
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3 text-center group-hover:text-purple-800 transition-colors">
            17 evropských zemí
          </h3>
          <p class="text-gray-600 leading-relaxed text-center">
            Zahrnuje společnosti z Německa, Francie, Švýcarska, Nizozemska, Velké Británie a dalších zemí.
          </p>
        </div>

        <div class="border-transparent shadow-none hover:shadow-md transition-shadow duration-200 group bg-white rounded-lg p-6">
          <div class="flex items-center justify-center rounded-full bg-gradient-to-r from-blue-500 to-cyan-600 w-16 h-16 mx-auto mb-6 group-hover:scale-110 transition-transform text-2xl">
            🏛️
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3 text-center group-hover:text-purple-800 transition-colors">
            90% evropského trhu
          </h3>
          <p class="text-gray-600 leading-relaxed text-center">
            Reprezentuje naprostou většinu tržní kapitalizace evropských akcií v rozvinutých zemích.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Top 3 Section -->
  <section id="top3" class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Top 3 ETF v této kategorii
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Naše doporučení na základě analýzy {etfs.length} ETF fondů
        </p>
      </div>
      <Top3ETF etfs={etfs} currency="EUR" />
    </div>
  </section>

  <!-- Top 10 Sections -->
  <Top10Sections etfs={etfs} currency="EUR" categoryName="STOXX 600" />

  <!-- Selection Guide -->
  <section id="pruvodce" class="py-20 bg-gradient-to-br from-purple-50 to-violet-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <div class="inline-flex items-center justify-center w-20 h-20 bg-gradient-to-r from-purple-600 to-violet-600 rounded-full mb-6 text-4xl">
          🎯
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          💡 Jak vybrat ten správný STOXX 600 ETF?
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="relative p-8 rounded-2xl bg-gradient-to-br from-green-50 to-emerald-50 border border-green-200 hover:shadow-lg transition-all duration-300">
          <div class="absolute -top-4 left-8 w-8 h-8 rounded-full bg-gradient-to-r from-green-400 to-emerald-500 flex items-center justify-center text-white font-bold text-sm">1</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4 mt-4">Pro začátečníky</h3>
          <p class="text-gray-700 leading-relaxed">
            Vyberte ETF s nejnižšími poplatky a velkou velikostí fondu. Zaměřte se na akumulační verze pro reinvestici výnosů.
          </p>
        </div>

        <div class="relative p-8 rounded-2xl bg-gradient-to-br from-blue-50 to-blue-50 border border-blue-200 hover:shadow-lg transition-all duration-300">
          <div class="absolute -top-4 left-8 w-8 h-8 rounded-full bg-gradient-to-r from-blue-400 to-blue-500 flex items-center justify-center text-white font-bold text-sm">2</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4 mt-4">Pro pokročilé</h3>
          <p class="text-gray-700 leading-relaxed">
            Porovnejte tracking error, likviditu a daňové aspekty různých jurisdikcí. Zvažte geografické rozložení indexu.
          </p>
        </div>

        <div class="relative p-8 rounded-2xl bg-gradient-to-br from-purple-50 to-purple-50 border border-purple-200 hover:shadow-lg transition-all duration-300">
          <div class="absolute -top-4 left-8 w-8 h-8 rounded-full bg-gradient-to-r from-purple-400 to-purple-500 flex items-center justify-center text-white font-bold text-sm">3</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4 mt-4">Pro dlouhodobé investory</h3>
          <p class="text-gray-700 leading-relaxed">
            Důraz na stabilitu providera, dlouhý track record a konzistentní sledování indexu. Preferujte akumulační varianty.
          </p>
        </div>

        <div class="relative p-8 rounded-2xl bg-gradient-to-br from-orange-50 to-orange-50 border border-orange-200 hover:shadow-lg transition-all duration-300">
          <div class="absolute -top-4 left-8 w-8 h-8 rounded-full bg-gradient-to-r from-orange-400 to-orange-500 flex items-center justify-center text-white font-bold text-sm">4</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4 mt-4">Pro minimalizaci nákladů</h3>
          <p class="text-gray-700 leading-relaxed">
            Hledejte ETF s nejnižším TER a sledujte i další náklady jako spread a tracking difference.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          ❓ Často kladené otázky
        </h2>
      </div>

      <div class="space-y-6">
        <details class="group border border-gray-200 rounded-lg hover:border-purple-200 transition-colors">
          <summary class="flex justify-between items-center w-full px-6 py-4 text-left bg-gray-50 cursor-pointer hover:bg-purple-50 rounded-lg group-open:rounded-b-none transition-colors">
            <span class="font-semibold text-lg text-gray-900 group-hover:text-purple-800">Jak jste vybrali TOP 3 STOXX 600 ETF?</span>
            <svg class="w-5 h-5 text-gray-500 group-hover:text-purple-600 transition-all group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 py-4 text-gray-700 leading-relaxed bg-white rounded-b-lg">
            Výběr je založen na kombinaci faktorů: nejnižší poplatky TER, velikost fondu, likvidita, tracking error a celková kvalita providera. Data čerpáme z naší databáze a aktualizujeme měsíčně.
          </div>
        </details>

        <details class="group border border-gray-200 rounded-lg hover:border-purple-200 transition-colors">
          <summary class="flex justify-between items-center w-full px-6 py-4 text-left bg-gray-50 cursor-pointer hover:bg-purple-50 rounded-lg group-open:rounded-b-none transition-colors">
            <span class="font-semibold text-lg text-gray-900 group-hover:text-purple-800">Co znamenají TOP 10 žebříčky na této stránce?</span>
            <svg class="w-5 h-5 text-gray-500 group-hover:text-purple-600 transition-all group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 py-4 text-gray-700 leading-relaxed bg-white rounded-b-lg">
            Žebříčky ukazují nejlepší STOXX 600 ETF podle různých kritérií - nejnižší poplatky, největší velikost fondu a nejvyšší výnosy za poslední rok. Data jsou živá z naší databáze.
          </div>
        </details>

        <details class="group border border-gray-200 rounded-lg hover:border-purple-200 transition-colors">
          <summary class="flex justify-between items-center w-full px-6 py-4 text-left bg-gray-50 cursor-pointer hover:bg-purple-50 rounded-lg group-open:rounded-b-none transition-colors">
            <span class="font-semibold text-lg text-gray-900 group-hover:text-purple-800">Proč se některé STOXX 600 ETF neobjevují v seznamech?</span>
            <svg class="w-5 h-5 text-gray-500 group-hover:text-purple-600 transition-all group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 py-4 text-gray-700 leading-relaxed bg-white rounded-b-lg">
            Odfiltrováváme malé fondy (pod 100 mil EUR), pákové produkty, tematické a sektorové ETF. Zaměřujeme se pouze na kvalitní širokoevropské ETF sledující celý STOXX 600 index.
          </div>
        </details>

        <details class="group border border-gray-200 rounded-lg hover:border-purple-200 transition-colors">
          <summary class="flex justify-between items-center w-full px-6 py-4 text-left bg-gray-50 cursor-pointer hover:bg-purple-50 rounded-lg group-open:rounded-b-none transition-colors">
            <span class="font-semibold text-lg text-gray-900 group-hover:text-purple-800">Akumulační vs distribuční STOXX 600 ETF?</span>
            <svg class="w-5 h-5 text-gray-500 group-hover:text-purple-600 transition-all group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 py-4 text-gray-700 leading-relaxed bg-white rounded-b-lg">
