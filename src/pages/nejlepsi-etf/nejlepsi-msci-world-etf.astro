---
import Layout from '../../layouts/Layout.astro';
import InternalLinking from '../../components/InternalLinking.astro';
import Top3ETFServer from '../../components/etf/Top3ETFServer';
import Top10SectionsServer from '../../components/etf/Top10SectionsServer';
import { getTopETFsForCategory, categoryConfigs } from '../../lib/etf-data';

const config = categoryConfigs['nejlepsi-msci-world-etf'];
const etfs = await getTopETFsForCategory(config);
const currentYear = new Date().getFullYear();
const currentDate = new Date().toLocaleDateString('cs-CZ', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
const lastModified = new Date().toISOString().split('T')[0];

// Enhanced structured data with FAQs and more products
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": `Nejlepší MSCI World ETF 2026 - SWDA vs XDWD vs SPPW`,
  "description": `Srovnání nejlepších MSCI World ETF 2026. SWDA, XDWD, SPPW - globální diverzifikace 1600+ společností, poplatky TER, výnosy.`,
  "image": "https://etfpruvodce.cz/og-msci-world-etf.jpg",
  "author": {
    "@type": "Person",
    "name": "Tomáš Kostrhoun",
    "url": "https://etfpruvodce.cz/o-nas#tomas-kostrhoun"
  },
  "publisher": {
    "@type": "Organization",
    "name": "ETF průvodce.cz",
    "logo": {
      "@type": "ImageObject",
      "url": "https://etfpruvodce.cz/logo.png"
    }
  },
  "datePublished": `2025-12-25`,
  "dateModified": lastModified,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://etfpruvodce.cz/nejlepsi-etf/nejlepsi-msci-world-etf"
  },
  "articleSection": "Investment Guides",
  "keywords": `MSCI World ETF, SWDA, XDWD, SPPW, globální diverzifikace, indexové fondy`,
  "wordCount": 3000,
  "inLanguage": "cs-CZ"
};

// FAQ structured data for better search snippets
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Jaké jsou nejlepší MSCI World ETF v roce 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nejlepší MSCI World ETF jsou: iShares Core MSCI World UCITS ETF (SWDA, IE00B4L5Y983) největší a nejlikvidnější s 75+ mld. EUR, Xtrackers MSCI World UCITS ETF (XDWD, IE00BJ0KDQ92) s konkurenceschopným TER 0,19% a 8+ mld. EUR, a SPDR MSCI World UCITS ETF (SPPW, IE00BFY0GT14) s nízkým TER 0,12% a 6+ mld. EUR."
      }
    },
    {
      "@type": "Question",
      "name": "Jaký je rozdíl mezi MSCI World a S&P 500?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "MSCI World pokrývá 23 rozvinutých zemí světa, zatímco S&P 500 pouze USA. MSCI World má širší geografickou diverzifikaci, ale nižší koncentraci technologických gigantů. Je méně volatilní, ale historicky má mírně nižší výnosy."
      }
    },
    {
      "@type": "Question",
      "name": "Který MSCI World ETF má nejnižší náklady?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nejnižší TER obvykle nabízejí někteří menší poskytovatelé ETF. Největší poskytovatelé mají vyšší poplatky, ale nabízejí lepší likviditu a delší track record. Podívejte se na náš žebříček podle TER pro aktuální srovnání."
      }
    },
    {
      "@type": "Question",
      "name": "Kolik zemí a společností obsahuje MSCI World index?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "MSCI World index obsahuje přes 1600 společností z 23 rozvinutých zemí světa. Zahrnuje USA (cca 70%), Japonsko (cca 7%), Velkou Británii (cca 4%), Francii, Německo, Kanadu, Švýcarsko, Austrálii a další vyspělé ekonomiky. Index pokrývá přibližně 85% tržní kapitalizace rozvinutých trhů."
      }
    },
    {
      "@type": "Question",
      "name": "Jaký je rozdíl mezi MSCI World a MSCI ACWI?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "MSCI World obsahuje pouze rozvinuté trhy (23 zemí), zatímco MSCI ACWI (All Country World Index) zahrnuje i emerging markets jako Čína, Indie, Brazílie nebo Korea. MSCI ACWI má přibližně 88% developed markets a 12% emerging markets, což poskytuje širší globální diverzifikaci."
      }
    },
    {
      "@type": "Question",
      "name": "Kde koupit MSCI World ETF v Česku?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "MSCI World ETF můžete koupit u většiny českých a evropských brokerů. Populární možnosti zahrnují Interactive Brokers, Degiro, XTB, Trading212, Portu nebo Fio e-Broker. Porovnejte si transakční poplatky a dostupnost konkrétních ETF jako SWDA, XDWD nebo SPPW u jednotlivých brokerů."
      }
    }
  ]
};

// Breadcrumb structured data
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Domů",
      "item": "https://etfpruvodce.cz"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Nejlepší ETF",
      "item": "https://etfpruvodce.cz/nejlepsi-etf"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Nejlepší MSCI World ETF",
      "item": "https://etfpruvodce.cz/nejlepsi-etf/nejlepsi-msci-world-etf"
    }
  ]
};

const relatedLinks = [
  { title: "Nejlepší S&P 500 ETF", href: "/nejlepsi-etf/nejlepsi-sp500-etf", description: "Srovnání amerických blue chip ETF na S&P 500 index", icon: "🇺🇸" },
  { title: "Nejlepší NASDAQ ETF", href: "/nejlepsi-etf/nejlepsi-nasdaq-etf", description: "Technologické ETF pro investice do NASDAQ 100", icon: "📈" },
  { title: "Kde koupit MSCI World ETF", href: "/kde-koupit-etf", description: "Srovnání brokerů pro investice do globálních ETF", icon: "🏦" },
  { title: "Portfolio strategie s MSCI World", href: "/portfolio-strategie", description: "Modelová portfolia obsahující globální ETF", icon: "📊" }
];

const faqItems = [
  {
    question: "Jaké jsou nejlepší MSCI World ETF v roce 2026?",
    answer: "Nejlepší MSCI World ETF jsou: iShares Core MSCI World UCITS ETF (SWDA, IE00B4L5Y983) největší a nejlikvidnější s 75+ mld. EUR, Xtrackers MSCI World UCITS ETF (XDWD, IE00BJ0KDQ92) s konkurenceschopným TER 0,19% a 8+ mld. EUR, a SPDR MSCI World UCITS ETF (SPPW, IE00BFY0GT14) s nízkým TER 0,12% a 6+ mld. EUR."
  },
  {
    question: "Co znamenají TOP 10 žebříčky podle TER, velikosti fondu a výkonu?",
    answer: "Naše žebříčky jsou generovány živě z databáze a filtrují pouze standardní MSCI World ETF. Automaticky vylučujeme tematické ETF (ESG, SRI, Value, Growth), small cap varianty a pákové produkty. Data jsou aktualizována pravidelně."
  },
  {
    question: "Jaký je rozdíl mezi MSCI World a S&P 500?",
    answer: "MSCI World pokrývá 23 rozvinutých zemí světa, zatímco S&P 500 pouze USA. MSCI World má širší geografickou diverzifikaci, ale nižší koncentraci technologických gigantů. Je méně volatilní, ale historicky má mírně nižší výnosy."
  },
  {
    question: "Proč má MSCI World nižší výnosy než NASDAQ nebo S&P 500?",
    answer: "MSCI World zahrnuje i pomalejší ekonomiky (Evropa, Japonsko) a má nižší váhu technologických akcií. Výměnou za mírně nižší výnosy získáváte lepší geografickou diverzifikaci a snížení závislosti na americkém trhu."
  },
  {
    question: "Který MSCI World ETF má nejnižší náklady?",
    answer: "Nejnižší TER obvykle nabízejí někteří menší poskytovatelé ETF. Největší poskytovatelé mají vyšší poplatky, ale nabízejí lepší likviditu a delší track record. Podívejte se na náš žebříček podle TER pro aktuální srovnání."
  },
  {
    question: "Jsou data v žebříčcích aktuální?",
    answer: "Ano, všechny žebříčky jsou generovány živě z naší databáze při každém načtení stránky. Zahrnují nejnovější data o TER, velikosti fondů, výkonnosti a dalších klíčových metrikách MSCI World ETF dostupných pro evropské investory."
  }
];
---

<Layout
  title={`Nejlepší MSCI World ETF 2026 - SWDA vs XDWD vs SPPW`}
  description={`Srovnání nejlepších MSCI World ETF 2026. SWDA, XDWD, SPPW - globální diverzifikace 1600+ společností, poplatky TER, výnosy. Aktuální data k ${currentDate}.`}
  canonical="/nejlepsi-etf/nejlepsi-msci-world-etf"
>
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Modern Hero Section -->
  <section class="relative py-16 md:py-24 bg-gradient-to-br from-gray-50 to-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-purple-50/50 via-pink-50/30 to-rose-50/50"></div>
    <div class="absolute top-20 left-1/4 w-72 h-72 bg-gradient-to-br from-purple-200 to-pink-200 rounded-full mix-blend-multiply filter blur-xl opacity-30 animate-pulse"></div>
    <div class="absolute top-40 right-1/4 w-72 h-72 bg-gradient-to-br from-pink-200 to-rose-200 rounded-full mix-blend-multiply filter blur-xl opacity-30 animate-pulse" style="animation-delay: 2s;"></div>
    <div class="absolute bottom-20 left-1/3 w-72 h-72 bg-gradient-to-br from-rose-200 to-red-200 rounded-full mix-blend-multiply filter blur-xl opacity-30 animate-pulse" style="animation-delay: 4s;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center w-full">

        <!-- Left Content -->
        <div class="space-y-8">
          <div class="inline-flex items-center bg-gradient-to-r from-purple-100 to-pink-100 text-purple-700 px-6 py-3 rounded-full text-sm font-medium backdrop-blur-sm border border-purple-200/50">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"></path></svg>
            Aktuální k {currentDate}
          </div>

          <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 leading-tight">
            Nejlepší{' '}
            <span class="bg-gradient-to-r from-purple-600 via-pink-600 to-rose-600 bg-clip-text text-transparent">
              MSCI World ETF
            </span>
          </h1>

          <!-- Author byline - E-E-A-T signal -->
          <div class="flex flex-wrap items-center gap-2 text-sm text-gray-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400">
              <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
            <span>Autor: </span>
            <a
              href="/o-nas"
              class="text-violet-600 hover:text-violet-700 font-medium hover:underline"
            >
              Tomáš Kostrhoun
            </a>
            <span class="text-gray-400">•</span>
            <span>
              Aktualizováno: {new Date(lastModified).toLocaleDateString('cs-CZ', {
                day: 'numeric',
                month: 'numeric',
                year: 'numeric'
              })}
            </span>
          </div>

          <p class="text-xl text-gray-600 leading-relaxed max-w-2xl">
            Kompletní srovnání nejlepších MSCI World ETF fondů pro globální diverzifikaci portfolia.
            Analýza poplatků, výkonnosti a praktické tipy pro výběr.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#top3" class="inline-flex items-center justify-center bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white px-8 py-4 text-lg font-semibold shadow-lg hover:shadow-xl transition-all rounded-xl">
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
              Top 3 doporučení
            </a>
            <a href="#srovnani" class="inline-flex items-center justify-center border-2 border-gray-300 text-gray-700 hover:bg-gray-50 px-8 py-4 text-lg font-semibold rounded-xl transition-colors">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
              Srovnání všech
            </a>
          </div>
        </div>

        <!-- Right Content - Market Stats -->
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-br from-white/60 to-gray-50/60 backdrop-blur-sm rounded-3xl shadow-2xl"></div>
          <div class="relative bg-gradient-to-br from-white/80 to-gray-50/60 backdrop-blur-sm rounded-3xl p-8 shadow-2xl border border-white/20">
            <div class="text-center mb-8">
              <h3 class="text-2xl font-bold text-gray-900 mb-2">🌍 MSCI World Stats</h3>
              <p class="text-gray-600">Klíčové informace o globálním indexu</p>
            </div>

            <!-- Stats Grid -->
            <div class="grid grid-cols-2 gap-6 mb-6">
              <div class="text-center p-4 bg-gradient-to-r from-purple-50 to-pink-50 rounded-xl border border-purple-200">
                <div class="text-3xl font-bold text-purple-600 mb-1">1600</div>
                <div class="text-sm text-gray-600">Firem z 23 zemí</div>
              </div>
              <div class="text-center p-4 bg-gradient-to-r from-pink-50 to-rose-50 rounded-xl border border-pink-200">
                <div class="text-3xl font-bold text-pink-600 mb-1">~9%</div>
                <div class="text-sm text-gray-600">Ročně za 20 let</div>
              </div>
              <div class="text-center p-4 bg-gradient-to-r from-rose-50 to-red-50 rounded-xl border border-rose-200">
                <div class="text-3xl font-bold text-rose-600 mb-1">85%</div>
                <div class="text-sm text-gray-600">Globální trh cap</div>
              </div>
              <div class="text-center p-4 bg-gradient-to-r from-red-50 to-orange-50 rounded-xl border border-red-200">
                <div class="text-3xl font-bold text-red-600 mb-1">{etfs.length}</div>
                <div class="text-sm text-gray-600">ETF na výběr</div>
              </div>
            </div>

            <div class="text-center pt-6 border-t border-gray-200/50">
              <p class="text-sm text-gray-600 mb-3">Developed markets po celém světě</p>
              <a href="#pruvodce" class="inline-flex items-center justify-center border border-purple-200 text-purple-600 hover:bg-purple-50 px-4 py-2 text-sm rounded-lg transition-colors">
                Průvodce výběrem
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Introduction Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          Co je MSCI World index?
        </h2>
        <p class="text-xl md:text-2xl text-gray-600 max-w-4xl mx-auto leading-relaxed">
          MSCI World obsahuje přes 1600 firem z 23 rozvinutých zemí světa.
          Je to nejpopulárnější index pro globální diverzifikaci portfolia.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
        <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-shadow border border-gray-100">
          <div class="flex items-center justify-center rounded-full bg-gradient-to-r from-purple-500 to-pink-600 w-16 h-16 mx-auto mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3 text-center">1600+ firem z 23 zemí</h3>
          <p class="text-gray-600 leading-relaxed text-center">
            Index pokrývá developed markets včetně USA, Evropy, Japonska, Kanady, Austrálie a dalších vyspělých ekonomik.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-shadow border border-gray-100">
          <div class="flex items-center justify-center rounded-full bg-gradient-to-r from-pink-500 to-rose-600 w-16 h-16 mx-auto mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3 text-center">Globální diverzifikace</h3>
          <p class="text-gray-600 leading-relaxed text-center">
            Rozložení rizika napříč kontinenty a ekonomikami. Žádná závislost na jedné zemi nebo regionu.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-shadow border border-gray-100">
          <div class="flex items-center justify-center rounded-full bg-gradient-to-r from-rose-500 to-red-600 w-16 h-16 mx-auto mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3 text-center">Large & mid cap focus</h3>
          <p class="text-gray-600 leading-relaxed text-center">
            Zaměření na velké a střední společnosti s prokázanou stabilitou a růstovým potenciálem.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Top 3 Recommendations - Server-side rendered with real data -->
  <section id="top3" class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          🏆 Top 3 nejlepší MSCI World ETF
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Naše doporučení na základě analýzy všech dostupných MSCI World ETF
        </p>
      </div>

      <Top3ETFServer etfs={etfs} currency="EUR" client:load />
    </div>
  </section>

  <!-- Top 10 Sections - by TER, AUM, Performance -->
  <Top10SectionsServer etfs={etfs} currency="EUR" categoryName="MSCI World" client:load />

  <!-- Selection Guide Section -->
  <section class="py-20 bg-gradient-to-br from-gray-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Selection Guide -->
      <div id="pruvodce" class="bg-gradient-to-br from-white to-purple-50 rounded-3xl p-12 border border-purple-100 shadow-xl">
        <div class="text-center mb-12">
          <div class="flex items-center justify-center rounded-full bg-gradient-to-r from-purple-100 to-pink-100 w-20 h-20 mx-auto mb-6">
