---
import '../styles/global.css';
import GlobalETFSearch from '../components/GlobalETFSearch';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  keywords?: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'ETF průvodce.cz - Kompletní databáze ETF fondů pro české investory',
  canonical,
  keywords,
  ogImage = '/og-image.jpg',
  ogTitle,
  ogDescription,
  ogType = 'website',
  twitterTitle,
  twitterDescription,
  noindex = false
} = Astro.props;

const finalOgTitle = ogTitle || title;
const finalOgDescription = ogDescription || description;
const finalTwitterTitle = twitterTitle || title;
const finalTwitterDescription = twitterDescription || description;

const siteUrl = 'https://www.etfpruvodce.cz';
const fullCanonical = canonical ? `${siteUrl}${canonical}` : siteUrl + Astro.url.pathname;
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

// Navigation items
const navigation = [
  { name: 'Co jsou ETF', href: '/co-jsou-etf' },
  { name: 'Kde koupit ETF', href: '/kde-koupit-etf' },
  { name: 'Srovnání ETF', href: '/srovnani-etf' },
  { name: 'Portfolio', href: '/portfolio-strategie' },
  { name: 'Kalkulačky', href: '/kalkulacky' },
  { name: 'Nejlepší ETF', href: '/nejlepsi-etf' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={fullCanonical} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={finalOgTitle} />
    <meta property="og:description" content={finalOgDescription} />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:site_name" content="ETF průvodce.cz" />
    <meta property="og:locale" content="cs_CZ" />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={finalTwitterTitle} />
    <meta name="twitter:description" content={finalTwitterDescription} />
    <meta name="twitter:image" content={fullOgImage} />

    <!-- Favicon & Theme -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="theme-color" content="#2563eb" />

    <!-- Google Verification -->
    <meta name="google-site-verification" content="xcO4Z-AnzPYJ288SOKyYz4KphoizdnaitN7V8e1yXKc" />

    <!-- Preconnect & Preload -->
    <link rel="dns-prefetch" href="https://nbhwnatadyubiuadfakx.supabase.co" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="preload" as="image" href="/logo.png" />

    <!-- Sitemap -->
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

    <!-- Font - Non-blocking load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" /></noscript>
  </head>

  <body class="min-h-screen bg-gray-50 font-sans antialiased">
    <!-- Header -->
    <header class="bg-white/80 backdrop-blur-lg sticky top-0 z-40 border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-20">
          <!-- Logo -->
          <div class="flex items-center">
            <a href="/" class="flex items-center group">
              <img src="/logo.png" alt="ETF průvodce.cz" class="h-20 w-auto group-hover:opacity-90 transition-opacity" />
            </a>
          </div>

          <!-- Desktop Search -->
          <div class="hidden lg:block flex-1 max-w-md mx-6">
            <GlobalETFSearch
              client:idle
              placeholder="Hledat ETF podle ISIN, nazvu..."
              className="w-full"
            />
          </div>

          <!-- Desktop Navigation -->
          <nav class="hidden md:flex space-x-1">
            {navigation.map((item) => (
              <a
                href={item.href}
                class:list={[
                  'px-4 py-2 rounded-md text-sm font-semibold transition-colors',
                  currentPath === item.href || currentPath.startsWith(item.href + '/')
                    ? 'text-violet-600 bg-violet-100'
                    : 'text-gray-600 hover:text-violet-600 hover:bg-violet-50'
                ]}
              >
                {item.name}
              </a>
            ))}
          </nav>

          <!-- Mobile Menu Button -->
          <button
            id="mobile-menu-btn"
            class="md:hidden p-2 rounded-md text-gray-600 hover:text-violet-600 hover:bg-violet-50"
            aria-label="Otevřít menu"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Search -->
      <div class="md:hidden lg:hidden border-t border-gray-100 px-4 py-3">
        <GlobalETFSearch
          client:idle
          placeholder="Hledat ETF..."
          className="w-full"
        />
      </div>

      <!-- Mobile Navigation -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100">
        <nav class="px-4 py-4 space-y-2">
          {navigation.map((item) => (
            <a
              href={item.href}
              class:list={[
                'block px-4 py-3 rounded-md text-base font-medium transition-colors',
                currentPath === item.href || currentPath.startsWith(item.href + '/')
                  ? 'text-violet-600 bg-violet-100'
                  : 'text-gray-600 hover:text-violet-600 hover:bg-violet-50'
              ]}
            >
              {item.name}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 mb-12">
          <!-- Company Info -->
          <div class="lg:col-span-1">
            <div class="flex items-center mb-6">
              <img src="/logo.png" alt="ETF průvodce.cz" class="h-10 w-auto" />
            </div>
            <p class="text-slate-400 leading-relaxed mb-6">
              Váš moderní a komplexní průvodce světem ETF fondů pro české investory.
              Srovnání, analýzy a vzdělávací obsah pro vaše investiční rozhodnutí.
            </p>
            <div class="space-y-3">
              <h4 class="text-slate-200 font-semibold">Kontakt</h4>
              <div class="flex items-center gap-3 text-slate-400">
                <span>✉</span>
                <a href="mailto:info@etfpruvodce.cz" class="hover:text-white transition-colors">
                  info@etfpruvodce.cz
                </a>
              </div>
            </div>
          </div>

          <!-- Navigation Links -->
          <div class="lg:col-span-2 grid grid-cols-1 sm:grid-cols-3 gap-8">
            <div>
              <h4 class="text-slate-200 font-semibold mb-4">Nástroje</h4>
              <ul class="space-y-3 text-slate-400">
                <li><a href="/srovnani-etf" class="hover:text-white transition-colors">Srovnání ETF</a></li>
                <li><a href="/portfolio-strategie" class="hover:text-white transition-colors">Portfolio Strategie</a></li>
                <li><a href="/kalkulacky" class="hover:text-white transition-colors">Kalkulačky</a></li>
                <li><a href="/nejlepsi-etf/nejlevnejsi-etf" class="hover:text-white transition-colors">Nejlevnější ETF</a></li>
              </ul>
            </div>

            <div>
              <h4 class="text-slate-200 font-semibold mb-4">Vzdělání</h4>
              <ul class="space-y-3 text-slate-400">
                <li><a href="/co-jsou-etf" class="hover:text-white transition-colors">Co jsou ETF</a></li>
                <li><a href="/kde-koupit-etf" class="hover:text-white transition-colors">Kde koupit ETF</a></li>
                <li><a href="/o-nas" class="hover:text-white transition-colors">O nás</a></li>
              </ul>
            </div>

            <div>
              <h4 class="text-slate-200 font-semibold mb-4">Brokeři</h4>
              <ul class="space-y-3 text-slate-400">
                <li><a href="/portu-recenze" class="hover:text-white transition-colors">Portu</a></li>
                <li><a href="/xtb-recenze" class="hover:text-white transition-colors">XTB</a></li>
                <li><a href="/degiro-recenze" class="hover:text-white transition-colors">DEGIRO</a></li>
                <li><a href="/trading212-recenze" class="hover:text-white transition-colors">Trading212</a></li>
                <li><a href="/interactive-brokers-recenze" class="hover:text-white transition-colors">Interactive Brokers</a></li>
                <li><a href="/fio-ebroker-recenze" class="hover:text-white transition-colors">Fio eBroker</a></li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Bottom Footer -->
        <div class="pt-8 border-t border-gray-800">
          <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
            <div class="flex flex-col sm:flex-row items-center gap-2 text-slate-500">
              <span>&copy; 2026 ETF průvodce.cz. Všechna práva vyhrazena.</span>
              <span class="hidden sm:inline">•</span>
              <span>
                Autor:
                <a href="https://www.linkedin.com/in/tomas-kostrhoun-b34a6831" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors ml-1">
                  Tomáš Kostrhoun
                </a>
              </span>
            </div>
          </div>
        </div>
      </div>
    </footer>

    <!-- Mobile Menu Script -->
    <script>
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');

      menuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });
    </script>

    <!-- Vercel Speed Insights -->
    <SpeedInsights />
  </body>
</html>
