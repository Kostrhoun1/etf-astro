---
interface Props {
  // Základní metriky
  ter: number | null;
  fundSize: number | null; // v mil EUR
  return1y?: number | null;
  return3y?: number | null;
  return5y?: number | null;
  trackingError?: number | null;
  category: string;
  distributionPolicy: string;
  replication: string;

  // Context pro srovnání
  avgTerInCategory?: number | null;
  avgFundSizeInCategory?: number | null;
}

const {
  ter,
  fundSize,
  return1y,
  return3y,
  return5y,
  trackingError,
  category,
  distributionPolicy,
  replication,
  avgTerInCategory = 0.25,
  avgFundSizeInCategory = 500
} = Astro.props;

// Safe number formatting helper
function safeToFixed(value: number | null | undefined, decimals: number = 2): string {
  if (value === null || value === undefined || isNaN(value)) return '0';
  return value.toFixed(decimals);
}

// === HODNOCENÍ NÁKLADOVOSTI (TER) ===
function rateCost(ter: number | null, avgTer: number | null) {
  const terValue = ter || 0;
  const avgValue = avgTer || 0.25;
  if (terValue < 0.10) return { rating: 5, text: 'Extrémně nízké poplatky', color: 'green', emoji: '🟢' };
  if (terValue < 0.20) return { rating: 4, text: 'Velmi nízké poplatky', color: 'emerald', emoji: '🟢' };
  if (terValue < avgValue) return { rating: 3, text: 'Průměrné poplatky', color: 'blue', emoji: '🔵' };
  if (terValue < avgValue * 1.5) return { rating: 2, text: 'Vyšší poplatky', color: 'orange', emoji: '🟠' };
  return { rating: 1, text: 'Vysoké poplatky', color: 'red', emoji: '🔴' };
}

// === HODNOCENÍ VELIKOSTI FONDU ===
function rateFundSize(size: number | null) {
  const sizeValue = size || 0;
  if (sizeValue > 5000) return { rating: 5, text: 'Mega fond - extrémní likvidita', color: 'green', emoji: '🟢' };
  if (sizeValue > 1000) return { rating: 4, text: 'Velký fond - vysoká likvidita', color: 'emerald', emoji: '🟢' };
  if (sizeValue > 100) return { rating: 3, text: 'Střední fond - dostatečná likvidita', color: 'blue', emoji: '🔵' };
  if (sizeValue > 50) return { rating: 2, text: 'Menší fond - nižší likvidita', color: 'orange', emoji: '🟠' };
  return { rating: 1, text: 'Malý fond - riziko zrušení', color: 'red', emoji: '🔴' };
}

// === HODNOCENÍ VÝKONNOSTI ===
function ratePerformance(ret1y: number | null | undefined, ret5y: number | null | undefined) {
  // Pokud nemáme data, neuhodnotíme
  if (!ret5y && !ret1y) return null;

  const relevantReturn = ret5y || ret1y || 0;

  if (relevantReturn > 100) return { rating: 5, text: 'Excelentní výkonnost', color: 'green', emoji: '🟢' };
  if (relevantReturn > 50) return { rating: 4, text: 'Velmi dobrá výkonnost', color: 'emerald', emoji: '🟢' };
  if (relevantReturn > 20) return { rating: 3, text: 'Průměrná výkonnost', color: 'blue', emoji: '🔵' };
  if (relevantReturn > 0) return { rating: 2, text: 'Slabá výkonnost', color: 'orange', emoji: '🟠' };
  return { rating: 1, text: 'Ztráta', color: 'red', emoji: '🔴' };
}

// === HODNOCENÍ TRACKING ERROR ===
function rateTrackingError(te: number | null | undefined) {
  if (!te) return null;

  if (te < 0.10) return { rating: 5, text: 'Excelentní kopírování indexu', color: 'green', emoji: '🟢' };
  if (te < 0.25) return { rating: 4, text: 'Velmi dobré kopírování', color: 'emerald', emoji: '🟢' };
  if (te < 0.50) return { rating: 3, text: 'Průměrné kopírování', color: 'blue', emoji: '🔵' };
  if (te < 1.00) return { rating: 2, text: 'Horší kopírování', color: 'orange', emoji: '🟠' };
  return { rating: 1, text: 'Špatné kopírování indexu', color: 'red', emoji: '🔴' };
}

// === CELKOVÝ RATING ===
function calculateOverallRating() {
  const costRating = rateCost(ter, avgTerInCategory);
  const sizeRating = rateFundSize(fundSize);
  const perfRating = ratePerformance(return1y, return5y);
  const teRating = rateTrackingError(trackingError);

  // Vážený průměr (nákladovost a velikost jsou důležitější)
  const weights = {
    cost: 0.35,
    size: 0.30,
    performance: perfRating ? 0.25 : 0,
    tracking: teRating ? 0.10 : 0
  };

  const totalWeight = weights.cost + weights.size + weights.performance + weights.tracking;

  const weightedRating =
    (costRating.rating * weights.cost +
      sizeRating.rating * weights.size +
      (perfRating?.rating || 0) * weights.performance +
      (teRating?.rating || 0) * weights.tracking) /
    totalWeight;

  return Math.round(weightedRating * 10) / 10;
}

// Vypočítej hodnocení
const costRating = rateCost(ter, avgTerInCategory);
const sizeRating = rateFundSize(fundSize);
const perfRating = ratePerformance(return1y, return5y);
const teRating = rateTrackingError(trackingError);
const overallRating = calculateOverallRating();

// Bonus body pro české investory
const czechBonusPoints = [];
if (distributionPolicy === 'Accumulating') {
  czechBonusPoints.push({ text: '+0.5 bodu za akumulační politiku (daňově výhodné)', bonus: 0.5 });
}
if (ter < 0.15) {
  czechBonusPoints.push({ text: '+0.3 bodu za extrémně nízký TER', bonus: 0.3 });
}
if (fundSize > 1000) {
  czechBonusPoints.push({ text: '+0.2 bodu za vysokou likviditu (nízký spread)', bonus: 0.2 });
}

const czechAdjustedRating = Math.min(5, overallRating + czechBonusPoints.reduce((sum, b) => sum + b.bonus, 0));
---

<section class="bg-gradient-to-br from-violet-50 via-blue-50 to-violet-50 rounded-2xl p-6 md:p-8 my-8 border-2 border-violet-200 shadow-lg">
  <!-- Hlavička -->
  <div class="flex items-start gap-3 mb-6">
    <span class="text-4xl">🇨🇿</span>
    <div>
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-2">
        Hodnocení ETF z pohledu českého investora
      </h2>
      <p class="text-gray-600 leading-relaxed">
        Hodnotíme na základě nákladovosti, likvidity, výkonnosti a vhodnosti pro české daňové prostředí.
        <strong>Toto je naše nezávislé hodnocení</strong>, ne databázový přehled.
      </p>
    </div>
  </div>

  <!-- CELKOVÉ HODNOCENÍ - BIG CARD -->
  <div class="bg-gradient-to-r from-violet-600 to-blue-600 rounded-xl p-6 md:p-8 text-white mb-8 shadow-xl">
    <div class="flex flex-col md:flex-row items-center md:items-start gap-6">
      <!-- Číslo ratingu -->
      <div class="bg-white/20 backdrop-blur-sm rounded-2xl p-6 text-center min-w-[140px]">
        <div class="text-6xl font-bold mb-2">{safeToFixed(czechAdjustedRating, 1)}</div>
        <div class="text-2xl text-yellow-300 mb-2">
          {'★'.repeat(Math.round(czechAdjustedRating))}{'☆'.repeat(5 - Math.round(czechAdjustedRating))}
        </div>
        <div class="text-sm opacity-90">z 5.0</div>
      </div>

      <!-- Text vysvětlení -->
      <div class="flex-1">
        <h3 class="text-2xl font-bold mb-3">
          {czechAdjustedRating >= 4.5 ? '🏆 Vynikající volba pro české investory' :
           czechAdjustedRating >= 4.0 ? '✅ Dobrá volba pro české investory' :
           czechAdjustedRating >= 3.5 ? '👍 Přijatelná volba' :
           czechAdjustedRating >= 3.0 ? '⚠️ Podmíněně vhodné' :
           '❌ Nedoporučujeme'}
        </h3>
        <p class="text-white/90 leading-relaxed mb-4">
          {czechAdjustedRating >= 4.5 ? 'Tento ETF splňuje všechna kritéria pro dlouhodobé investování českého investora. Nízké náklady, vysoká likvidita a vhodná struktura pro daňovou optimalizaci.' :
           czechAdjustedRating >= 4.0 ? 'Solidní ETF s dobrými parametry. Vhodné pro dlouhodobé investování s minimálními riziky.' :
           czechAdjustedRating >= 3.5 ? 'Průměrné ETF, které může být vhodné v určitých situacích, ale existují lepší alternativy.' :
           czechAdjustedRating >= 3.0 ? 'Toto ETF má některé nevýhody (vyšší poplatky / nízká likvidita). Zvažte alternativy.' :
           'Toto ETF nedoporučujeme kvůli vysokým poplatkům nebo jiným rizikům. Najděte lepší alternativu.'}
        </p>

        <!-- Czech bonus points -->
        {czechBonusPoints.length > 0 && (
          <div class="bg-white/10 rounded-lg p-4 backdrop-blur-sm">
            <div class="font-semibold mb-2">🇨🇿 Bonusové body pro české investory:</div>
            <ul class="space-y-1 text-sm text-white/90">
              {czechBonusPoints.map(bonus => (
                <li>✓ {bonus.text}</li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- DETAILNÍ HODNOCENÍ KATEGORIÍ -->
  <div class="space-y-6">
    <!-- 1. NÁKLADOVOST -->
    <div class="bg-white rounded-xl p-6 border-2 border-gray-200 hover:border-violet-300 transition-colors">
      <div class="flex items-center justify-between mb-4 flex-wrap gap-3">
        <div class="flex items-center gap-3">
          <span class="text-3xl">{costRating.emoji}</span>
          <div>
            <h3 class="text-lg font-bold text-gray-900">Nákladovost (TER)</h3>
            <p class="text-sm text-gray-600">Jak nízké jsou roční poplatky</p>
          </div>
        </div>
        <div class="text-right">
          <div class="text-2xl font-bold" style={`color: ${costRating.rating >= 4 ? '#15803d' : costRating.rating >= 3 ? '#1d4ed8' : '#c2410c'}`}>
            {'★'.repeat(costRating.rating)}{'☆'.repeat(5 - costRating.rating)}
          </div>
          <div class="text-sm text-gray-600">{costRating.rating}/5</div>
        </div>
      </div>

      <!-- Progress bar -->
      <div class="mb-4">
        <div class="bg-gray-200 rounded-full h-3">
          <div
            class="h-3 rounded-full transition-all"
            style={`width: ${(costRating.rating / 5) * 100}%; background-color: ${costRating.rating >= 4 ? '#10b981' : costRating.rating >= 3 ? '#3b82f6' : '#f97316'}`}
          ></div>
        </div>
      </div>

      <!-- Interpretace -->
      <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
        <div class="font-semibold text-gray-900 mb-2">{costRating.text}</div>
        <p class="text-sm text-gray-700 leading-relaxed mb-3">
          TER <strong>{safeToFixed(ter, 2)}%</strong> znamená, že při investici <strong>1 000 000 Kč</strong>
          zaplatíte ročně <strong>{((ter || 0) * 10000).toLocaleString('cs-CZ')} Kč</strong>.
        </p>

        <!-- Porovnání s průměrem -->
        <div class="grid md:grid-cols-2 gap-3 text-sm">
          <div class="bg-white rounded p-3 border border-gray-200">
            <div class="text-gray-600 mb-1">Toto ETF</div>
            <div class="font-bold text-gray-900">{safeToFixed(ter, 2)}% TER</div>
          </div>
          <div class="bg-white rounded p-3 border border-gray-200">
            <div class="text-gray-600 mb-1">Průměr kategorie</div>
            <div class="font-bold text-gray-900">{safeToFixed(avgTerInCategory, 2)}% TER</div>
          </div>
        </div>

        <div class="mt-3 p-3 bg-blue-50 rounded border border-blue-200">
          <p class="text-xs text-blue-900">
            <strong>💡 Pro české investory:</strong> Za 30 let rozdíl 0.15% v TER znamená ztrátu {((0.0015 * 1000000 * 30) / 1000).toFixed(0)}k Kč na každém milionu!
            {ter < 0.15 ? ' Proto je tento nízký TER tak důležitý.' : ' Proto doporučujeme hledat ETF s nižším TER.'}
          </p>
        </div>
      </div>
    </div>

    <!-- 2. VELIKOST FONDU -->
    <div class="bg-white rounded-xl p-6 border-2 border-gray-200 hover:border-violet-300 transition-colors">
      <div class="flex items-center justify-between mb-4 flex-wrap gap-3">
        <div class="flex items-center gap-3">
          <span class="text-3xl">{sizeRating.emoji}</span>
          <div>
            <h3 class="text-lg font-bold text-gray-900">Velikost fondu</h3>
            <p class="text-sm text-gray-600">Likvidita a stabilita</p>
          </div>
        </div>
        <div class="text-right">
          <div class="text-2xl font-bold" style={`color: ${sizeRating.rating >= 4 ? '#15803d' : sizeRating.rating >= 3 ? '#1d4ed8' : '#c2410c'}`}>
            {'★'.repeat(sizeRating.rating)}{'☆'.repeat(5 - sizeRating.rating)}
          </div>
          <div class="text-sm text-gray-600">{sizeRating.rating}/5</div>
        </div>
      </div>

      <div class="mb-4">
        <div class="bg-gray-200 rounded-full h-3">
          <div
            class="h-3 rounded-full transition-all"
            style={`width: ${(sizeRating.rating / 5) * 100}%; background-color: ${sizeRating.rating >= 4 ? '#10b981' : sizeRating.rating >= 3 ? '#3b82f6' : '#f97316'}`}
          ></div>
        </div>
      </div>

      <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
        <div class="font-semibold text-gray-900 mb-2">{sizeRating.text}</div>
        <p class="text-sm text-gray-700 leading-relaxed mb-3">
          Fond spravuje <strong>{(fundSize || 0) >= 1000 ? `${safeToFixed((fundSize || 0) / 1000, 1)} mld EUR` : `${fundSize || 0} mil EUR`}</strong>.
          {fundSize && fundSize > 1000 && ' To je obrovský fond s vynikající likviditou.'}
          {fundSize && fundSize > 100 && fundSize <= 1000 && ' To je solidní velikost zajišťující dobrou likviditu.'}
          {fundSize && fundSize <= 100 && fundSize > 50 && ' Menší fond, sledujte vývoj velikosti.'}
          {fundSize && fundSize <= 50 && ' Malý fond - hrozí riziko zrušení při poklesu aktiv.'}
        </p>

        <div class="mt-3 p-3 bg-blue-50 rounded border border-blue-200">
          <p class="text-xs text-blue-900">
            <strong>💡 Pro české investory:</strong> Větší fondy mají nižší spread (rozdíl mezi nákupní a prodejní cenou).
            U mega fondů je spread často 0.01-0.03%, u malých fondů může být 0.5% a víc.
          </p>
        </div>
      </div>
    </div>

    <!-- 3. VÝKONNOST (pokud jsou data) -->
    {perfRating && (
      <div class="bg-white rounded-xl p-6 border-2 border-gray-200 hover:border-violet-300 transition-colors">
        <div class="flex items-center justify-between mb-4 flex-wrap gap-3">
          <div class="flex items-center gap-3">
            <span class="text-3xl">{perfRating.emoji}</span>
            <div>
              <h3 class="text-lg font-bold text-gray-900">Historická výkonnost</h3>
              <p class="text-sm text-gray-600">Minulá výkonnost (není zárukou budoucnosti)</p>
            </div>
          </div>
          <div class="text-right">
            <div class="text-2xl font-bold" style={`color: ${perfRating.rating >= 4 ? '#15803d' : perfRating.rating >= 3 ? '#1d4ed8' : '#c2410c'}`}>
              {'★'.repeat(perfRating.rating)}{'☆'.repeat(5 - perfRating.rating)}
            </div>
            <div class="text-sm text-gray-600">{perfRating.rating}/5</div>
          </div>
        </div>

        <div class="mb-4">
          <div class="bg-gray-200 rounded-full h-3">
            <div
              class="h-3 rounded-full transition-all"
              style={`width: ${(perfRating.rating / 5) * 100}%; background-color: ${perfRating.rating >= 4 ? '#10b981' : perfRating.rating >= 3 ? '#3b82f6' : '#f97316'}`}
            ></div>
          </div>
        </div>

        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
          <div class="font-semibold text-gray-900 mb-2">{perfRating.text}</div>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-3 text-sm">
            {return1y !== null && return1y !== undefined && (
              <div class="bg-white rounded p-3 border border-gray-200">
                <div class="text-gray-600 mb-1">1 rok</div>
                <div class="font-bold text-gray-900">{return1y > 0 ? '+' : ''}{safeToFixed(return1y, 2)}%</div>
              </div>
            )}
            {return3y !== null && return3y !== undefined && (
              <div class="bg-white rounded p-3 border border-gray-200">
                <div class="text-gray-600 mb-1">3 roky</div>
                <div class="font-bold text-gray-900">{return3y > 0 ? '+' : ''}{safeToFixed(return3y, 2)}%</div>
              </div>
            )}
            {return5y !== null && return5y !== undefined && (
              <div class="bg-white rounded p-3 border border-gray-200">
                <div class="text-gray-600 mb-1">5 let</div>
                <div class="font-bold text-gray-900">{return5y > 0 ? '+' : ''}{safeToFixed(return5y, 2)}%</div>
              </div>
            )}
          </div>

          <div class="mt-3 p-3 bg-yellow-50 rounded border border-yellow-200">
            <p class="text-xs text-yellow-900">
              <strong>⚠️ Upozornění:</strong> Historická výkonnost není zárukou budoucích výnosů.
              ETF kopírují index, takže výkonnost závisí na vývoji trhů, ne na schopnostech managementu.
            </p>
          </div>
        </div>
      </div>
    )}

    <!-- 4. TRACKING ERROR (pokud jsou data) -->
    {teRating && (
      <div class="bg-white rounded-xl p-6 border-2 border-gray-200 hover:border-violet-300 transition-colors">
        <div class="flex items-center justify-between mb-4 flex-wrap gap-3">
          <div class="flex items-center gap-3">
            <span class="text-3xl">{teRating.emoji}</span>
            <div>
              <h3 class="text-lg font-bold text-gray-900">Tracking Error</h3>
              <p class="text-sm text-gray-600">Jak přesně kopíruje index</p>
            </div>
          </div>
          <div class="text-right">
            <div class="text-2xl font-bold" style={`color: ${teRating.rating >= 4 ? '#15803d' : teRating.rating >= 3 ? '#1d4ed8' : '#c2410c'}`}>
              {'★'.repeat(teRating.rating)}{'☆'.repeat(5 - teRating.rating)}
            </div>
            <div class="text-sm text-gray-600">{teRating.rating}/5</div>
          </div>
        </div>

        <div class="mb-4">
          <div class="bg-gray-200 rounded-full h-3">
            <div
              class="h-3 rounded-full transition-all"
              style={`width: ${(teRating.rating / 5) * 100}%; background-color: ${teRating.rating >= 4 ? '#10b981' : teRating.rating >= 3 ? '#3b82f6' : '#f97316'}`}
            ></div>
          </div>
        </div>

        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
          <div class="font-semibold text-gray-900 mb-2">{teRating.text}</div>
          <p class="text-sm text-gray-700 leading-relaxed">
            Tracking error <strong>{safeToFixed(trackingError, 2)}%</strong> znamená průměrnou odchylku od indexu.
            {trackingError && trackingError < 0.25 && ' To je vynikající přesnost.'}
          </p>
        </div>
      </div>
    )}
  </div>

  <!-- Shrnutí pro rychlé rozhodnutí -->
  <div class="mt-8 bg-gradient-to-r from-gray-50 to-violet-50 rounded-xl p-6 border-2 border-gray-200">
    <h3 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
      <span>⚡</span>
      Rychlé rozhodnutí
    </h3>
    <div class="space-y-3 text-sm">
      <div class="flex items-start gap-3">
        <span class="text-lg">{czechAdjustedRating >= 4.5 ? '✅' : czechAdjustedRating >= 3.5 ? '👍' : '⚠️'}</span>
        <p class="text-gray-700">
          <strong>Celkové hodnocení:</strong> {safeToFixed(czechAdjustedRating, 1)}/5.0 hvězdiček z pohledu českého investora
        </p>
      </div>
      <div class="flex items-start gap-3">
        <span class="text-lg">{costRating.rating >= 4 ? '✅' : '⚠️'}</span>
        <p class="text-gray-700">
          <strong>Náklady:</strong> {costRating.text} ({safeToFixed(ter, 2)}% TER)
        </p>
      </div>
      <div class="flex items-start gap-3">
        <span class="text-lg">{sizeRating.rating >= 4 ? '✅' : sizeRating.rating >= 3 ? '👍' : '⚠️'}</span>
        <p class="text-gray-700">
          <strong>Likvidita:</strong> {sizeRating.text}
        </p>
      </div>
      <div class="flex items-start gap-3">
        <span class="text-lg">{distributionPolicy === 'Accumulating' ? '✅' : '⚠️'}</span>
        <p class="text-gray-700">
          <strong>Daňová optimalizace:</strong> {distributionPolicy === 'Accumulating' ? 'Akumulační (ideální pro ČR)' : 'Distribuční (méně výhodné)'}
        </p>
      </div>
    </div>
  </div>
</section>
