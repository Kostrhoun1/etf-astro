        'Kombinace: 70% S&P 500 + 20% Bonds + 10% Gold = All-Weather portfolio'
      ]
    }
  }
};

const categoryInsights = insights[categoryKey as keyof typeof insights];

if (!categoryInsights) {
  // Fallback pro kategorie bez specifických insights
  return null;
}
---

<section class="py-16 bg-gradient-to-br from-orange-50 via-amber-50 to-yellow-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Hlavní nadpis -->
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        {categoryInsights.title}
      </h2>
      <p class="text-xl text-gray-600">
        Specifická rizika a příležitosti pro české investory
      </p>
    </div>

    <!-- Rizika -->
    <div class="mb-12">
      <h3 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
        <span class="text-3xl">⚠️</span>
        Rizika, která musíte znát
      </h3>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {categoryInsights.risks.map((risk) => (
          <div class={`rounded-2xl p-6 border-2 ${
            risk.severity === 'high'
              ? 'bg-red-50 border-red-300'
              : risk.severity === 'medium'
              ? 'bg-orange-50 border-orange-300'
              : 'bg-yellow-50 border-yellow-300'
          }`}>
            <div class="text-4xl mb-3">{risk.emoji}</div>
            <h4 class="text-lg font-bold text-gray-900 mb-2">{risk.title}</h4>
            <p class="text-sm text-gray-700 leading-relaxed">{risk.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Výhody -->
    <div class="mb-12">
      <h3 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
        <span class="text-3xl">✅</span>
        Proč to dává smysl
      </h3>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {categoryInsights.advantages.map((advantage) => (
          <div class="bg-green-50 rounded-2xl p-6 border-2 border-green-300">
            <div class="text-4xl mb-3">{advantage.emoji}</div>
            <h4 class="text-lg font-bold text-gray-900 mb-2">{advantage.title}</h4>
            <p class="text-sm text-gray-700 leading-relaxed">{advantage.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- České specifika -->
    <div class="bg-white rounded-2xl p-8 border-2 border-blue-300 shadow-lg">
      <h3 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
        <span class="text-3xl">{categoryInsights.czechSpecific.emoji}</span>
        {categoryInsights.czechSpecific.title}
      </h3>
      <ul class="space-y-4">
        {categoryInsights.czechSpecific.points.map((point) => (
          <li class="flex items-start gap-3">
            <span class="text-blue-600 text-xl mt-1">•</span>
            <span class="text-gray-700 leading-relaxed">{point}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
