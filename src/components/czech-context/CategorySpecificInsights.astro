      ]
    }
  },

  'bonds': {
    title: 'Dluhopisové ETF v prostředí vysokých sazeb',
    risks: [
      {
        emoji: '📉',
        title: 'Úrokové riziko',
        description: 'Když ČNB/Fed zvyšuje sazby, ceny dluhopisů klesají. V 2022 dluhopisové ETF -15% ztráta.',
        severity: 'medium'
      },
      {
        emoji: '🔥',
        title: 'Inflační eroze',
