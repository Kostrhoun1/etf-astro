---
// Unikátní expertní analýzy pro každou kategorii ETF z pohledu českých investorů
// Gemini Strategy: Přidává specifický český kontext, který templated content nemá

interface Props {
  categoryKey: string; // např. 'sp500', 'nasdaq', 'msci-world'
  categoryName: string; // např. 'S&P 500', 'NASDAQ 100'
}

const { categoryKey, categoryName } = Astro.props;

// Definice insights pro každou kategorii
const insights = {
  'sp500': {
    title: 'S&P 500 z pohledu českých investorů',
