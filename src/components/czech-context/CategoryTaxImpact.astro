---
// Daňové důsledky pro konkrétní kategorii ETF v ČR
// Gemini Strategy: Praktický český kontext - daně, přiznání, optimalizace

interface Props {
  categoryKey: string;
  categoryName: string;
}

const { categoryKey, categoryName } = Astro.props;

// Daňové specifika pro každou kategorii
const taxInfo = {
  'sp500': {
    dividendPolicy: 'Většinou akumulační (CSPX, VUAA) nebo distribuční (VUSA, SPY5)',
    withholdingTax: '15% USA withholding tax na dividendy',
    czechTax: '15% daň v ČR (po odečtu USA daně)',
    scenarios: [
      {
        title: 'Akumulační ETF (CSPX) - DOPORUČENO',
        description: 'Dividendy se reinvestují automaticky uvnitř fondu',
        taxEvents: [
          { event: 'Nákup', tax: '0 Kč', note: 'Žádná daň' },
          { event: 'Držba (1-10 let)', tax: '0 Kč', note: 'Žádná průběžná daň' },
          { event: 'Prodej po 3 letech', tax: '0 Kč', note: 'Osvobození od daně (§4 odst. 1 písm. w)' },
          { event: 'Prodej před 3 lety', tax: '15% ze zisku', note: 'Daň z kapitálového zisku' }
        ],
        totalTax: '0 Kč při držbě 3+ let',
        example: 'Nakoupil jste za 100k Kč, po 5 letech prodáváte za 200k Kč → zisk 100k Kč → daň 0 Kč ✅'
      },
      {
        title: 'Distribuční ETF (VUSA) - KOMPLIKOVANĚJŠÍ',
        description: 'Dividendy se vyplácejí 4x ročně na váš účet',
        taxEvents: [
          { event: 'Dividend payment (4x ročně)', tax: '15% USA + 15% ČR', note: 'Broker strhne 15% USA, zbytek danit v přiznání' },
          { event: 'Daňové přiznání', tax: 'Povinné každý rok', note: 'Administrativní zátěž' },
          { event: 'Prodej po 3 letech', tax: '0 Kč (kapitálový zisk)', note: 'Osvobození od daně' }
        ],
        totalTax: '~300-500 Kč ročně účetní + administrativní čas',
        example: 'Portfolio 500k Kč, dividend yield 1,5% → 7 500 Kč dividend/rok → 15% USA daň (1 125 Kč) → odečtete v přiznání'
      }
    ],
    recommendation: 'VŽDY voli akumulační ETF (CSPX, VUAA). Ušetříte administrativu i daně.'
  },

  'nasdaq': {
    dividendPolicy: 'Většinou akumulační (EQQQ, CNDX)',
    withholdingTax: '15% USA withholding tax',
    czechTax: '15% v ČR',
    scenarios: [
      {
        title: 'Akumulační NASDAQ ETF (EQQQ) - IDEÁLNÍ',
        description: 'Tech firmy platí nízké dividendy (~0,5%), reinvestují do růstu',
        taxEvents: [
          { event: 'Držba 10 let', tax: '0 Kč', note: 'Žádná průběžná daň' },
          { event: 'Prodej po 3 letech', tax: '0 Kč', note: 'Osvobození' }
        ],
        totalTax: '0 Kč',
        example: 'NASDAQ ideální pro mladé investory - nulová daň 10+ let, pak prodej bez daně'
      }
    ],
    recommendation: 'NASDAQ je daňově nejefektivnější - nízké dividendy + akumulační struktura = 0 Kč daní při hold 3+ let'
  },

  'msci-world': {
    dividendPolicy: 'Akumulační i distribuční verze dostupné',
    withholdingTax: '15-30% závislé na domicilu fondu (Irsko 15%, Lucembursko 15%)',
    czechTax: '15% v ČR',
    scenarios: [
      {
        title: 'Irský ETF (SWDA) - OPTIMÁLNÍ',
        description: 'Irsko má daňovou smlouvu s USA - pouze 15% withholding tax',
        taxEvents: [
          { event: 'Držba + prodej po 3 letech', tax: '0 Kč', note: 'Akumulační struktura' }
        ],
        totalTax: '0 Kč',
        example: 'Držíte 20 let → prodáte v důchodu → 0 Kč daň'
      }
    ],
    recommendation: 'Vždy volte irský domicil ETF (IE prefix v ISIN) - nejnižší withholding tax'
  },

  'emerging-markets': {
    dividendPolicy: 'Většinou akumulační',
    withholdingTax: 'Komplexní - Čína 10%, Indie 20%, Brazílie 15%',
    czechTax: '15% v ČR',
    scenarios: [
      {
        title: 'EM ETF - Withholdingová daň komplex',
        description: 'Každá země má jinou srážkovou daň na dividendy',
        taxEvents: [
          { event: 'Čínské akcie', tax: '10% withheld', note: 'Nižší než USA' },
          { event: 'Indické akcie', tax: '20% withheld', note: 'Vyšší než USA' },
          { event: 'Prodej po 3 letech', tax: '0 Kč v ČR', note: 'Osvobození kapitálového zisku' }
        ],
        totalTax: 'Průměrně ~12-15% withheld na dividendy (automaticky)',
        example: 'Akumulační EM ETF + hold 3+ let = ideální daňová optimalizace'
      }
    ],
    recommendation: 'Akumulační EM ETF eliminují složitost daní z různých zemí'
  },

  'bonds': {
    dividendPolicy: 'Většinou distribuční (vyplácejí kupony)',
    withholdingTax: '0-15% závislé na typu dluhopisu',
    czechTax: '15% v ČR z kuponových plateb',
    scenarios: [
      {
        title: 'Dluhopisové ETF v ČR',
        description: 'Kupony = pravidelný příjem → daň každý rok',
        taxEvents: [
          { event: 'Kuponové platby (2-4x ročně)', tax: '15% v ČR', note: 'Musíte uvést v daňovém přiznání' },
          { event: 'Prodej ETF', tax: '0 Kč po 3 letech', note: 'Kapitálový zisk osvobozen' }
        ],
        totalTax: '15% z kuponů ročně',
        example: 'Portfolio 500k Kč, yield 4% → 20k Kč kuponů/rok → 3k Kč daň/rok'
      }
    ],
    recommendation: 'Dluhopisy nejsou tax-efficient v ČR. Zvažte stavební spoření (osvobozené od daně) nebo termínované vklady.'
  },

  'gold': {
    dividendPolicy: 'Žádné dividendy (zlato neplatí dividendy)',
    withholdingTax: 'N/A',
    czechTax: '15% při prodeji před 3 lety',
    scenarios: [
      {
        title: 'Gold ETF - Daňově čisté',
        description: 'Žádné průběžné daně, pouze při prodeji',
        taxEvents: [
          { event: 'Držba 1-50 let', tax: '0 Kč', note: 'Žádná průběžná daň' },
          { event: 'Prodej po 3 letech', tax: '0 Kč', note: 'Osvobození' },
          { event: 'Prodej před 3 lety', tax: '15% ze zisku', note: 'Kapitálový zisk' }
        ],
        totalTax: '0 Kč při hold 3+ let',
        example: 'Zlato ideální pro buy-and-hold - žádné dividendy = žádná průběžná daň'
      }
    ],
    recommendation: 'Fyzické zlato vs Gold ETF: Tax-wise stejné. ETF lepší likvidita, nižší náklady.'
  }
};

const category = taxInfo[categoryKey as keyof typeof taxInfo];

if (!category) {
  return null;
}

const currentYear = new Date().getFullYear();
---

<section class="py-16 bg-gradient-to-br from-slate-50 to-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Hlavní nadpis -->
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Daňové důsledky {categoryName} ETF v ČR
      </h2>
      <p class="text-xl text-gray-600">
        Praktický průvodce daněmi pro české investory ({currentYear})
      </p>
    </div>

    <!-- Základní info -->
    <div class="grid md:grid-cols-3 gap-6 mb-12">
      <div class="bg-white rounded-xl p-6 border-2 border-blue-200">
        <div class="text-3xl mb-3">📋</div>
        <h3 class="font-bold text-gray-900 mb-2">Dividendová politika</h3>
        <p class="text-sm text-gray-700">{category.dividendPolicy}</p>
      </div>

      <div class="bg-white rounded-xl p-6 border-2 border-orange-200">
        <div class="text-3xl mb-3">🌍</div>
        <h3 class="font-bold text-gray-900 mb-2">Srážková daň (withholding)</h3>
        <p class="text-sm text-gray-700">{category.withholdingTax}</p>
      </div>

      <div class="bg-white rounded-xl p-6 border-2 border-green-200">
        <div class="text-3xl mb-3">🇨🇿</div>
        <h3 class="font-bold text-gray-900 mb-2">Česká daň</h3>
        <p class="text-sm text-gray-700">{category.czechTax}</p>
      </div>
    </div>

    <!-- Scénáře -->
    <div class="space-y-8 mb-12">
      {category.scenarios.map((scenario) => (
        <div class="bg-white rounded-2xl p-8 border-2 border-purple-300 shadow-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-3">{scenario.title}</h3>
          <p class="text-gray-700 mb-6">{scenario.description}</p>

          <!-- Tax events table -->
          <div class="overflow-x-auto mb-6">
            <table class="w-full">
              <thead>
                <tr class="border-b-2 border-purple-300">
                  <th class="text-left py-3 px-4 text-gray-900 font-bold">Událost</th>
                  <th class="text-right py-3 px-4 text-gray-900 font-bold">Daň</th>
                  <th class="text-left py-3 px-4 text-gray-900 font-bold">Poznámka</th>
                </tr>
              </thead>
              <tbody>
                {scenario.taxEvents.map((event) => (
                  <tr class="border-b border-purple-200">
                    <td class="py-3 px-4 text-gray-900">{event.event}</td>
                    <td class="py-3 px-4 text-right font-bold text-gray-900">{event.tax}</td>
                    <td class="py-3 px-4 text-sm text-gray-600">{event.note}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <!-- Total tax -->
          <div class="bg-gradient-to-br from-green-50 to-emerald-50 rounded-xl p-6 border-l-4 border-green-500 mb-4">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-2xl">💰</span>
              <h4 class="font-bold text-gray-900">Celkové daňové náklady</h4>
            </div>
            <p class="text-xl font-bold text-green-700">{scenario.totalTax}</p>
          </div>

          <!-- Example -->
          <div class="bg-blue-50 rounded-xl p-4 border-l-4 border-blue-500">
            <p class="text-sm text-gray-700">
              <strong>Příklad:</strong> {scenario.example}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Doporučení -->
    <div class="bg-gradient-to-br from-yellow-50 to-orange-50 rounded-2xl p-8 border-2 border-yellow-300">
      <h3 class="text-2xl font-bold text-gray-900 mb-4 flex items-center gap-3">
        <span class="text-3xl">💡</span>
        Daňové doporučení pro české investory
      </h3>
      <p class="text-lg text-gray-700 leading-relaxed">{category.recommendation}</p>
    </div>

    <!-- Klíčové body -->
    <div class="mt-12 bg-white rounded-2xl p-8 border-2 border-gray-300">
      <h3 class="text-2xl font-bold text-gray-900 mb-6">
        ⚖️ Klíčové body českého daňového práva
      </h3>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-green-50 rounded-xl p-6 border-l-4 border-green-500">
          <h4 class="font-bold text-green-800 mb-3">✅ 3-leté osvobození (§4 odst. 1 písm. w)</h4>
          <p class="text-sm text-gray-700 mb-3">
            Prodej cenných papírů po <strong>3 letech držby</strong> je osvobozen od daně z kapitálového zisku.
          </p>
          <p class="text-xs text-gray-600 italic">
            Zákon č. 586/1992 Sb., o daních z příjmů
          </p>
        </div>

        <div class="bg-blue-50 rounded-xl p-6 border-l-4 border-blue-500">
          <h4 class="font-bold text-blue-800 mb-3">📅 Daňové přiznání deadline</h4>
          <p class="text-sm text-gray-700 mb-3">
            Pokud máte příjmy z dividend (distribuční ETF), musíte podat daňové přiznání <strong>do 1. dubna</strong> následujícího roku.
          </p>
          <p class="text-xs text-gray-600 italic">
            U akumulačních ETF přiznání NENÍ nutné (dividendy se reinvestují uvnitř fondu)
          </p>
        </div>

        <div class="bg-orange-50 rounded-xl p-6 border-l-4 border-orange-500">
          <h4 class="font-bold text-orange-800 mb-3">💼 Zahraniční daň (ř. 63)</h4>
          <p class="text-sm text-gray-700 mb-3">
            Pokud vám broker strhl srážkovou daň v zahraničí (např. 15% USA), můžete si ji <strong>odečíst v řádku 63</strong> daňového přiznání.
          </p>
          <p class="text-xs text-gray-600 italic">
            Obvykle neplatíte dodatečně v ČR, ale musíte to uvést
          </p>
        </div>

        <div class="bg-purple-50 rounded-xl p-6 border-l-4 border-purple-500">
          <h4 class="font-bold text-purple-800 mb-3">🧮 FIFO pravidlo</h4>
          <p class="text-sm text-gray-700 mb-3">
            Při prodeji části portfolia se uplatňuje <strong>FIFO (First In, First Out)</strong> - prodáváte nejstarší nákupy jako první.
          </p>
          <p class="text-xs text-gray-600 italic">
            Důležité pro 3-leté osvobození: starší nákupy se uvolňují dříve
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
