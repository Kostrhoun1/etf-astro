---
/**
 * Server-side Top 3 ETF Cards Component
 * Renders top 3 ETF data statically for SEO
 */
import type { ETFBasicInfo } from '../../lib/etf-data';

interface Props {
  etfs: ETFBasicInfo[];
  currency?: 'EUR' | 'CZK' | 'USD';
}

const { etfs, currency = 'EUR' } = Astro.props;

function formatNumber(num: number | null | undefined): string {
  if (num === null || num === undefined) return 'N/A';
  return new Intl.NumberFormat('cs-CZ').format(num);
}

function formatPercentage(num: number | null | undefined): string {
  if (num === null || num === undefined) return 'N/A';
  return (num > 0 ? '+' : '') + num.toFixed(1) + '%';
}

function getReturnValue(etf: ETFBasicInfo, curr: 'EUR' | 'CZK' | 'USD'): number | null {
  switch (curr) {
    case 'CZK':
      return etf.return_1y_czk;
    case 'USD':
      return etf.return_1y_usd;
    default:
      return etf.return_1y;
  }
}

const top3 = etfs.slice(0, 3);

const rankColors = [
  { bg: 'bg-yellow-50', border: 'border-yellow-400', badge: 'bg-yellow-400' },
  { bg: 'bg-gray-50', border: 'border-gray-300', badge: 'bg-gray-300' },
  { bg: 'bg-orange-50', border: 'border-orange-300', badge: 'bg-orange-300' },
];
---

{top3.length > 0 && (
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    {top3.map((etf, index) => {
      const return1y = getReturnValue(etf, currency);
      const colors = rankColors[index] || rankColors[2];

      return (
        <div
          class={`relative ${colors.bg} border-2 ${colors.border} rounded-xl p-5 transition-shadow hover:shadow-lg`}
        >
          {/* Rank badge */}
          <div class={`absolute -top-3 -left-3 w-10 h-10 ${colors.badge} rounded-full flex items-center justify-center shadow-md`}>
            <span class="text-white font-bold text-lg">#{index + 1}</span>
          </div>

          {/* Trophy for #1 */}
          {index === 0 && (
            <div class="absolute top-2 right-2">
              <svg class="w-6 h-6 text-yellow-500" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2L9 8H2l6 4.5-2 7L12 15l6 4.5-2-7L22 8h-7z"/>
              </svg>
            </div>
          )}

          <div class="mt-4">
            <a
              href={`/etf/${etf.isin}`}
              class="font-semibold text-gray-900 hover:text-violet-600 transition-colors text-lg block"
            >
              {etf.name}
            </a>

            <div class="flex items-center gap-2 mt-2 text-sm text-gray-500">
              <span class="font-mono">{etf.isin}</span>
              {etf.primary_ticker && (
                <span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded text-xs font-medium">
                  {etf.primary_ticker}
                </span>
              )}
            </div>

            {/* Rating stars */}
            {etf.rating && etf.rating >= 3 && (
              <div class="flex items-center gap-1 mt-2">
                {[...Array(5)].map((_, i) => (
                  <svg
                    class={`w-4 h-4 ${i < Math.round(etf.rating!) ? 'text-yellow-400' : 'text-gray-200'}`}
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                ))}
                <span class="text-sm text-gray-500 ml-1">({etf.rating.toFixed(1)})</span>
              </div>
            )}

            {/* Key metrics */}
            <div class="grid grid-cols-2 gap-3 mt-4">
              <div class="bg-white rounded-lg p-3 text-center shadow-sm">
                <div class="text-xs text-gray-500 mb-1">TER (poplatky)</div>
                <div class="font-semibold text-gray-900">
                  {etf.ter_numeric !== null ? `${etf.ter_numeric.toFixed(2)}%` : 'N/A'}
                </div>
              </div>
              <div class="bg-white rounded-lg p-3 text-center shadow-sm">
                <div class="text-xs text-gray-500 mb-1">1R výnos ({currency})</div>
                <div class={`font-semibold ${return1y !== null && return1y > 0 ? 'text-green-600' : 'text-red-600'}`}>
                  {formatPercentage(return1y)}
                </div>
              </div>
            </div>

            {/* Additional info */}
            <div class="mt-4 space-y-2">
              <div class="flex items-center text-sm text-gray-600">
                <svg class="w-4 h-4 text-green-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Velikost: {formatNumber(etf.fund_size_numeric)} mil. EUR
              </div>
              {etf.fund_provider && (
                <div class="flex items-center text-sm text-gray-600">
                  <svg class="w-4 h-4 text-green-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  Poskytovatel: {etf.fund_provider}
                </div>
              )}
            </div>

            {/* CTA button */}
            <a
              href={`/etf/${etf.isin}`}
              class="mt-4 block w-full text-center bg-violet-600 hover:bg-violet-700 text-white font-medium py-2.5 px-4 rounded-lg transition-colors"
            >
              Zobrazit detail
            </a>
          </div>
        </div>
      );
    })}
  </div>
)}
