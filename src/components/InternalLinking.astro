---
interface RelatedLink {
  title: string;
  description: string;
  href: string;
  icon?: string;
}

interface Props {
  links: RelatedLink[];
  title?: string;
  className?: string;
}

const {
  links,
  title = "Související články a nástroje",
  className = ""
} = Astro.props;

if (!links || links.length === 0) {
  return null;
}
---

<section class={`bg-gray-50 rounded-lg p-8 ${className}`}>
  <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">
    {title}
  </h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {links.map((link) => (
      <div class="bg-white rounded-lg shadow hover:shadow-lg transition-shadow duration-200 overflow-hidden">
        <div class="p-6 pb-3">
          <div class="flex items-center gap-3 mb-2">
            {link.icon && <span>{link.icon}</span>}
            <h3 class="text-lg font-semibold text-gray-900">{link.title}</h3>
          </div>
          <p class="text-sm text-gray-600">
            {link.description}
          </p>
        </div>
        <div class="px-6 pb-6 pt-0">
          <a
            href={link.href}
            class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-800 font-medium text-sm group"
          >
            Přečíst více
            <span class="group-hover:translate-x-1 transition-transform" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    ))}
  </div>
</section>
