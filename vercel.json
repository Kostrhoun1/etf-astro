{
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "framework": "astro",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.etfpruvodce.cz"
        }
      ],
      "destination": "https://etfpruvodce.cz/:path*",
      "permanent": true
    }
  ]
}
